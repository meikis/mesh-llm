@@ -0,0 +1,122 @@
+#include "chat.h"
+#include "skippy.h"
+
+#include <cstdlib>
+#include <cstring>
+#include <exception>
+#include <limits>
+#include <string>
+
+static skippy_error * skippy_common_make_error(enum skippy_status status, const char * message) {
+    skippy_error * error = new skippy_error{};
+    error->status = status;
+
+    if (message == nullptr) {
+        error->message = nullptr;
+        return error;
+    }
+
+    const size_t len = std::strlen(message);
+    char * owned = static_cast<char *>(std::malloc(len + 1));
+    if (owned == nullptr) {
+        error->status = SKIPPY_STATUS_ERROR;
+        error->message = nullptr;
+        return error;
+    }
+
+    std::memcpy(owned, message, len + 1);
+    error->message = owned;
+    return error;
+}
+
+static void skippy_common_set_error(
+        skippy_error ** out_error,
+        enum skippy_status status,
+        const char * message) {
+    if (out_error != nullptr) {
+        *out_error = skippy_common_make_error(status, message);
+    }
+}
+
+static enum skippy_status skippy_common_success(skippy_error ** out_error) {
+    if (out_error != nullptr) {
+        *out_error = nullptr;
+    }
+    return SKIPPY_STATUS_OK;
+}
+
+enum skippy_status skippy_apply_chat_template(
+        struct skippy_model * model,
+        const struct llama_chat_message * messages,
+        size_t message_count,
+        bool add_assistant,
+        char * output_text,
+        size_t output_text_capacity,
+        size_t * out_text_bytes,
+        struct skippy_error ** out_error) {
+    if (out_text_bytes == nullptr) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "out_text_bytes is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (message_count > 0 && messages == nullptr) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "messages are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (output_text_capacity > static_cast<size_t>(std::numeric_limits<int32_t>::max())) {
+        skippy_common_set_error(
+                out_error,
+                SKIPPY_STATUS_INVALID_ARGUMENT,
+                "chat template output capacity exceeds int32_t range");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    const llama_model * native_model = skippy_model_native_model(model);
+    if (native_model == nullptr) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "model is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    common_chat_templates_ptr tmpls;
+    common_chat_templates_inputs inputs;
+    inputs.add_generation_prompt = add_assistant;
+    inputs.use_jinja             = true;
+    inputs.messages.reserve(message_count);
+
+    for (size_t i = 0; i < message_count; ++i) {
+        if (messages[i].role == nullptr || messages[i].content == nullptr) {
+            skippy_common_set_error(
+                    out_error,
+                    SKIPPY_STATUS_INVALID_ARGUMENT,
+                    "message role and content are required");
+            return SKIPPY_STATUS_INVALID_ARGUMENT;
+        }
+        common_chat_msg msg;
+        msg.role = messages[i].role;
+        msg.content = messages[i].content;
+        inputs.messages.emplace_back(std::move(msg));
+    }
+
+    std::string prompt;
+    try {
+        tmpls = common_chat_templates_init(native_model, "");
+        prompt = common_chat_templates_apply(tmpls.get(), inputs).prompt;
+    } catch (const std::exception & e) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, e.what());
+        return SKIPPY_STATUS_UNSUPPORTED;
+    } catch (...) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "failed to apply chat template");
+        return SKIPPY_STATUS_UNSUPPORTED;
+    }
+
+    *out_text_bytes = prompt.size();
+    if (output_text == nullptr || output_text_capacity < prompt.size()) {
+        skippy_common_set_error(
+                out_error,
+                SKIPPY_STATUS_BUFFER_TOO_SMALL,
+                "chat template output buffer is too small");
+        return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+    }
+    if (!prompt.empty()) {
+        std::memcpy(output_text, prompt.data(), prompt.size());
+    }
+    return skippy_common_success(out_error);
+}
