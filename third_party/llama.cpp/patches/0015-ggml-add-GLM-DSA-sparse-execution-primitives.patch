+        motif.ids->ne[0] == 8 &&
+        motif.ids->ne[1] == 1 &&
+        motif.down->src[0]->ne[0] == 2048 &&
+        motif.down->src[0]->ne[1] == 6144 &&
+        motif.down->src[0]->ne[2] == 256 &&
+        motif.out->ne[0] == 6144 &&
