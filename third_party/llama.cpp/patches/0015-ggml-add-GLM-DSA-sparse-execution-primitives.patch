+    }
+    return motif.gate->type == GGML_TYPE_F32 &&
+        motif.up->type == GGML_TYPE_F32 &&
+        motif.glu->type == GGML_TYPE_F32 &&
+        motif.down->type == GGML_TYPE_F32 &&
+        motif.out->type == GGML_TYPE_F32 &&
+        motif.down->src[0]->type == GGML_TYPE_Q2_K &&
