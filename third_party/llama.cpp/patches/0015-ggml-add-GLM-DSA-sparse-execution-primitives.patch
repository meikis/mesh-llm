+        cmd_buf,
+        fusion_scratch,
+        fusion_scratch_size,
+        gf,
+        idx_start,
+        idx_end,
+        use_fusion,
+        use_concurrency,
+        use_capture,
+        debug_graph,
+        debug_fusion);
