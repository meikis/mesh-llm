+            ne11,
+            ne12,
+            (unsigned long long) nb10,
+            (unsigned long long) nb11,
+            (unsigned long long) nb12,
+            ne20,
+            ne21,
+            (unsigned long long) nb21,
+            (unsigned long long) nb31,
+            (unsigned long long) nb32,
