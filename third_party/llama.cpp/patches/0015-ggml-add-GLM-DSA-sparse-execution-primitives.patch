+        motif.glu->type == GGML_TYPE_F32 &&
+        dst->type == GGML_TYPE_F32 &&
+        motif.up->src[0]->ne[0] >= 2048 &&
+        motif.up->src[0]->ne[1] >= 1024 &&
+        motif.up->src[0]->ne[2] == 256 &&
+        motif.gate->src[0]->ne[0] >= 2048 &&
