+static int64_t llama_glm_dsa_kq_mask_nbytes(
+        ggml_type type,
+        int64_t   n_kv,
+        int64_t   n_batch,
+        int64_t   n_stream) {
+    return (int64_t) ggml_row_size(type, n_kv) * n_batch * n_stream;
+}
