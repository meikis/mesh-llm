         /*.gtype       =*/ gtype,
+        /*.skippy_glm_dsa_phase_hint =*/ skippy_graph_get_filter().glm_dsa_phase_hint,
+        /*.layer_backend_device_types =*/ std::move(layer_backend_device_types),
