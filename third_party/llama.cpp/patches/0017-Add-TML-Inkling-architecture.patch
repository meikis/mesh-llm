+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, **kwargs)
+        assert self.hparams_vision is not None
+        hp = self.hparams_vision
+        expected = {
+            "vision_encoder_type": "hmlp",
+            "patch_size": 40,
+            "temporal_patch_size": 2,
+            "n_channels": 3,
+            "n_layers": 4,
+            "decoder_dmodel": 6144,
+            "use_vision_norm": True,
