+struct test_data {
+    std::vector<float> q;
+    std::vector<float> k;
+    std::vector<float> v;
+    std::vector<float> rel;
+    std::vector<ggml_fp16_t> mask;
+    std::vector<uint8_t> k_typed;
+    std::vector<uint8_t> v_typed;
+    std::vector<uint8_t> rel_typed;
