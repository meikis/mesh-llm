+    {{- '<|content_thinking|>' -}}{{- content -}}
+  {%- elif kind == 'xml' -%}
+    {{- '<|content_xml|>' -}}{{- content -}}
+  {%- elif kind == 'invoke_tool_json' -%}
+    {{- '<|content_invoke_tool_json|>' -}}{{- content -}}
+  {%- elif kind == 'image' -%}
+    {{- '<|content_image|><|image|>' -}}
+  {%- elif kind == 'audio' -%}
