+struct bias_test_config {
+    const char * name;
+    int64_t d;
+    int64_t nq;
+    int64_t nkv;
+    int64_t hq;
+    int64_t hkv;
+    int64_t extent;
+    ggml_type type;
+    bool use_mask;
