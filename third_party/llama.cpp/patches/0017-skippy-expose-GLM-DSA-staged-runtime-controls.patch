 #include "skippy.h"
 
 #include "nlohmann/json.hpp"
@@ -369,3 +370,47 @@ enum skippy_status skippy_parse_chat_response_json(
     skippy_common_copy_output(output, output_message_json);
     return skippy_common_success(out_error);
 }
+
+enum skippy_status skippy_ngram_simple_draft(
+        const llama_token * token_history,
+        size_t token_history_count,
+        llama_token sampled_token,
+        uint16_t ngram_size,
+        uint16_t max_draft_tokens,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        size_t * out_token_count,
+        skippy_error ** out_error) {
+    if (out_token_count == nullptr) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "out_token_count is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    *out_token_count = 0;
+    if (ngram_size == 0 || max_draft_tokens == 0) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "ngram and draft sizes must be greater than zero");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (token_history_count > 0 && token_history == nullptr) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "token_history is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    llama_tokens history;
+    if (token_history_count > 0) {
+        history.assign(token_history, token_history + token_history_count);
+    }
+    const common_ngram_simple_config config {
+        /* .size_ngram = */ ngram_size,
+        /* .size_mgram = */ max_draft_tokens,
+    };
+    const llama_tokens draft = common_ngram_simple_draft(config, history, sampled_token);
+    *out_token_count = draft.size();
+    if (draft.size() > output_token_capacity || (!draft.empty() && output_tokens == nullptr)) {
+        skippy_common_set_error(out_error, SKIPPY_STATUS_BUFFER_TOO_SMALL, "draft token buffer is too small");
+        return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+    }
+    if (!draft.empty()) {
+        std::memcpy(output_tokens, draft.data(), draft.size() * sizeof(llama_token));
+    }
+    return skippy_common_success(out_error);
+}
