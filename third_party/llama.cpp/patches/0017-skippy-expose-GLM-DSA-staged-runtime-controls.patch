+enum skippy_status skippy_verify_branch_batch_frame_sampled(
+        struct skippy_session * session,
+        const struct skippy_branch_batch_desc * branch_desc,
+        const llama_token * token_ids,
+        const uint32_t * position_offsets,
+        const uint32_t * sequence_offsets,
+        const uint32_t * sequence_ids,
+        const struct skippy_sampling_config * sampling,
+        const struct skippy_activation_desc * input_desc,
+        const void * input_payload,
+        struct skippy_activation_desc * output_desc,
+        void * output_payload,
+        size_t output_payload_capacity,
+        size_t * out_output_payload_bytes,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        size_t * out_token_count,
+        struct skippy_error ** out_error) {
+    if (out_token_count != nullptr) {
+        *out_token_count = 0;
+    }
+    std::vector<llama_pos> max_positions;
+    uint32_t max_memberships = 0;
+    enum skippy_status status = skippy_validate_branch_batch(
+            session,
+            branch_desc,
+            token_ids,
+            position_offsets,
+            sequence_offsets,
+            sequence_ids,
+            max_positions,
+            max_memberships,
+            out_error);
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+
+    const size_t token_count = branch_desc->token_count;
+    status = skippy_validate_frame_input_sequences(
+            session,
+            input_desc,
+            input_payload,
+            token_count,
+            branch_desc->sequence_count,
+            out_error);
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    status = skippy_prepare_output_activation_frame(
+            session,
+            token_count,
+            output_payload,
+            output_payload_capacity,
+            out_output_payload_bytes,
+            output_desc,
+            input_desc,
+            out_error);
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    if (output_desc != nullptr) {
+        output_desc->sequence_count = branch_desc->sequence_count;
+    }
+    if (session->stage_model->config.include_output) {
+        if (out_token_count == nullptr || output_tokens == nullptr || output_token_capacity < token_count) {
+            skippy_set_error(out_error, SKIPPY_STATUS_BUFFER_TOO_SMALL, "branch output token buffer is too small");
+            return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+        }
+    }
+
+    session->ctx->synchronize();
+    llama_memory_t memory = session->ctx->get_memory();
+    if (memory == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "runtime memory is unavailable");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    session->pending_branch_count = branch_desc->sequence_count;
+    session->pending_branch_max_pos = max_positions;
+    for (uint32_t logical_id = 0; logical_id < branch_desc->sequence_count; ++logical_id) {
+        const llama_seq_id physical_id = skippy_branch_sequence_id(session, logical_id);
+        if (physical_id < 0) {
+            skippy_clear_pending_branches(session);
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to map logical branch sequence");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+        if (logical_id == 0 && session->branch_mirror_valid &&
+            session->branch_mirror_n_past <= session->n_past) {
+            if (session->branch_mirror_n_past < session->n_past) {
+                llama_memory_seq_rm(memory, physical_id, session->branch_mirror_n_past, -1);
+                llama_memory_seq_cp(
+                        memory,
+                        session->seq_id,
+                        physical_id,
+                        session->branch_mirror_n_past,
+                        session->n_past);
+            }
+        } else {
+            llama_memory_seq_rm(memory, physical_id, -1, -1);
+            llama_memory_seq_cp(memory, session->seq_id, physical_id, 0, session->n_past);
+        }
+        if (logical_id == 0) {
+            session->branch_mirror_valid = true;
+            session->branch_mirror_n_past = session->n_past;
+        }
+    }
+
+    const bool activation_input = skippy_is_filtered(session) && session->stage_model->config.layer_start > 0;
+    const int32_t n_tokens = static_cast<int32_t>(token_count);
+    const int32_t n_embd = activation_input ? llama_model_n_embd(session->stage_model->model) : 0;
+    llama_batch batch = llama_batch_init(n_tokens, n_embd, static_cast<int32_t>(max_memberships));
+    batch.n_tokens = n_tokens;
+    if (activation_input) {
+        const size_t hidden_bytes = skippy_activation_hidden_bytes(session, token_count);
+        std::memcpy(batch.embd, input_payload, hidden_bytes);
+    }
+    for (int32_t token_index = 0; token_index < n_tokens; ++token_index) {
+        if (!activation_input) {
+            batch.token[token_index] = token_ids[token_index];
+        }
+        batch.pos[token_index] = session->n_past + static_cast<llama_pos>(position_offsets[token_index]);
+        const uint32_t begin = sequence_offsets[token_index];
+        const uint32_t end = sequence_offsets[token_index + 1];
+        batch.n_seq_id[token_index] = static_cast<int32_t>(end - begin);
+        for (uint32_t membership = begin; membership < end; ++membership) {
+            batch.seq_id[token_index][membership - begin] =
+                    skippy_branch_sequence_id(session, sequence_ids[membership]);
+        }
+        batch.logits[token_index] = 1;
+    }
+
+    const size_t hidden_bytes = activation_input ? skippy_activation_hidden_bytes(session, token_count) : 0;
+    const int32_t n_altup = static_cast<int32_t>(session->stage_model->model->hparams.n_altup);
+    skippy_activation_tokens_scope activation_tokens_scope(token_ids, token_count);
+    skippy_rwkv7_v_first_scope rwkv7_v_first_scope(input_desc, input_payload, hidden_bytes, n_embd);
+    skippy_gemma3n_altup_scope gemma3n_altup_scope(input_desc, input_payload, n_embd, n_altup);
+    skippy_glm_dsa_top_k_scope glm_dsa_top_k_scope(
+            input_desc,
+            input_payload,
+            hidden_bytes,
+            skippy_glm_dsa_top_k_count_from_desc(session, input_desc),
+            skippy_glm_dsa_n_stream(session),
+            session->n_past);
+
+    const int32_t saved_n_past = session->n_past;
+    status = skippy_decode_batch(
+            session,
+            batch,
+            token_count,
+            SKIPPY_GLM_DSA_PHASE_HINT_VERIFY,
+            out_error);
+    session->n_past = saved_n_past;
+    llama_batch_free(batch);
+    if (status != SKIPPY_STATUS_OK) {
+        skippy_clear_pending_branches(session);
+        return status;
+    }
+
+    status = skippy_copy_output_activation_frame(
+            session,
+            token_count,
+            output_payload,
+            input_desc,
+            input_payload,
+            out_output_payload_bytes,
+            output_desc,
+            out_error);
+    if (status != SKIPPY_STATUS_OK) {
+        skippy_clear_pending_branches(session);
+        return status;
+    }
+    if (output_desc != nullptr) {
+        output_desc->sequence_count = branch_desc->sequence_count;
+    }
+    if (session->stage_model->config.include_output) {
+        for (int32_t token_index = 0; token_index < n_tokens; ++token_index) {
+            output_tokens[token_index] = skippy_sample_token_ith(session, sampling, token_index);
+        }
+        *out_token_count = token_count;
+    }
+
+    return skippy_success(out_error);
+}
