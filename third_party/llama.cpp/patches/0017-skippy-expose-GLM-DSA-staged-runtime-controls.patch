+static llama_seq_id skippy_branch_sequence_id(
+        const skippy_session * session,
+        uint32_t logical_sequence_id) {
+    const skippy_model * model = session != nullptr ? session->stage_model : nullptr;
+    if (model == nullptr ||
+        logical_sequence_id >= model->branch_sequence_capacity ||
+        session->seq_id < 0) {
+        return -1;
+    }
+    const uint64_t branch_base = static_cast<uint64_t>(model->lane_count) * 2;
+    const uint64_t lane_base = static_cast<uint64_t>(session->seq_id) * model->branch_sequence_capacity;
+    const uint64_t physical_id = branch_base + lane_base + logical_sequence_id;
+    return physical_id <= static_cast<uint64_t>(std::numeric_limits<llama_seq_id>::max())
+        ? static_cast<llama_seq_id>(physical_id)
+        : -1;
+}
+
+static void skippy_clear_pending_branches(skippy_session * session) {
+    if (session == nullptr || session->ctx == nullptr) {
+        return;
+    }
+    const uint32_t branch_count = std::max(
+            session->pending_branch_count,
+            session->branch_mirror_valid ? 1u : 0u);
+    if (llama_memory_t memory = session->ctx->get_memory()) {
+        for (uint32_t logical_id = 0; logical_id < branch_count; ++logical_id) {
+            const llama_seq_id physical_id = skippy_branch_sequence_id(session, logical_id);
+            if (physical_id >= 0) {
+                llama_memory_seq_rm(memory, physical_id, -1, -1);
+            }
+        }
+    }
+    session->pending_branch_count = 0;
+    session->pending_branch_max_pos.clear();
+    session->branch_mirror_valid = false;
+    session->branch_mirror_n_past = 0;
+}
