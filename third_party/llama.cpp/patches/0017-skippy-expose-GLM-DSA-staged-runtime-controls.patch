+static enum skippy_status skippy_validate_branch_batch(
+        skippy_session * session,
+        const skippy_branch_batch_desc * branch_desc,
+        const llama_token * token_ids,
+        const uint32_t * position_offsets,
+        const uint32_t * sequence_offsets,
+        const uint32_t * sequence_ids,
+        std::vector<llama_pos> & out_max_positions,
+        uint32_t & out_max_memberships,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->ctx == nullptr || session->stage_model == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (branch_desc == nullptr || token_ids == nullptr || position_offsets == nullptr ||
+        sequence_offsets == nullptr || sequence_ids == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch descriptor and CSR batch arrays are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (branch_desc->version != 1 || branch_desc->token_count == 0 ||
+        branch_desc->sequence_count == 0 || branch_desc->sequence_membership_count == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch descriptor must be version 1 with non-zero counts");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (branch_desc->sequence_count > session->stage_model->branch_sequence_capacity) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch batch exceeds configured per-lane sequence capacity");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (branch_desc->token_count > static_cast<uint32_t>(std::numeric_limits<int32_t>::max()) ||
+        branch_desc->token_count > llama_n_ubatch(session->ctx)) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch batch must fit in one physical microbatch");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (session->pending_branch_count != 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "a branch batch is already pending commit or discard");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (sequence_offsets[0] != 0 ||
+        sequence_offsets[branch_desc->token_count] != branch_desc->sequence_membership_count) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch sequence offsets do not cover the membership array");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    out_max_positions.assign(branch_desc->sequence_count, session->n_past - 1);
+    std::vector<bool> sequence_seen(branch_desc->sequence_count, false);
+    out_max_memberships = 0;
+    for (uint32_t token_index = 0; token_index < branch_desc->token_count; ++token_index) {
+        const uint32_t begin = sequence_offsets[token_index];
+        const uint32_t end = sequence_offsets[token_index + 1];
+        if (begin >= end || end > branch_desc->sequence_membership_count) {
+            skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "every branch token must belong to at least one sequence");
+            return SKIPPY_STATUS_INVALID_ARGUMENT;
+        }
+        out_max_memberships = std::max(out_max_memberships, end - begin);
+        if (position_offsets[token_index] > static_cast<uint32_t>(std::numeric_limits<llama_pos>::max() - session->n_past)) {
+            skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch token position exceeds llama position range");
+            return SKIPPY_STATUS_INVALID_ARGUMENT;
+        }
+        const llama_pos position = session->n_past + static_cast<llama_pos>(position_offsets[token_index]);
+        uint32_t previous_logical_id = std::numeric_limits<uint32_t>::max();
+        for (uint32_t membership = begin; membership < end; ++membership) {
+            const uint32_t logical_id = sequence_ids[membership];
+            if (logical_id >= branch_desc->sequence_count || logical_id == previous_logical_id) {
+                skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "branch sequence membership is invalid or duplicated");
+                return SKIPPY_STATUS_INVALID_ARGUMENT;
+            }
+            if (position != out_max_positions[logical_id] + 1) {
+                skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "each branch must contain contiguous token positions");
+                return SKIPPY_STATUS_INVALID_ARGUMENT;
+            }
+            out_max_positions[logical_id] = position;
+            sequence_seen[logical_id] = true;
+            previous_logical_id = logical_id;
+        }
+    }
+    if (std::find(sequence_seen.begin(), sequence_seen.end(), false) != sequence_seen.end()) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "every declared branch sequence must contain a token");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    return SKIPPY_STATUS_OK;
+}
