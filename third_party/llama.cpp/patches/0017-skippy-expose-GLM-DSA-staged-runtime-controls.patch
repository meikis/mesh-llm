+enum skippy_status skippy_commit_branch_batch(
+        struct skippy_session * session,
+        uint32_t sequence_id,
+        const llama_token * accepted_tokens,
+        size_t accepted_token_count,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->ctx == nullptr || session->pending_branch_count == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "a pending branch batch is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (sequence_id >= session->pending_branch_count ||
+        accepted_tokens == nullptr || accepted_token_count == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "accepted branch sequence and tokens are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    const llama_pos max_position = session->pending_branch_max_pos[sequence_id];
+    const size_t branch_token_count = max_position >= session->n_past
+        ? static_cast<size_t>(max_position - session->n_past + 1)
+        : 0;
+    if (accepted_token_count > branch_token_count ||
+        accepted_token_count > static_cast<size_t>(std::numeric_limits<int32_t>::max() - session->n_past)) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "accepted token count exceeds the selected branch");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    session->ctx->synchronize();
+    llama_memory_t memory = session->ctx->get_memory();
+    const llama_seq_id physical_id = skippy_branch_sequence_id(session, sequence_id);
+    if (memory == nullptr || physical_id < 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "runtime branch memory is unavailable");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    const llama_pos commit_end = session->n_past + static_cast<llama_pos>(accepted_token_count);
+    llama_memory_seq_rm(memory, session->seq_id, session->n_past, -1);
+    llama_memory_seq_cp(memory, physical_id, session->seq_id, session->n_past, commit_end);
+    const llama_seq_id mirror_id = skippy_branch_sequence_id(session, 0);
+    if (mirror_id < 0) {
+        skippy_clear_pending_branches(session);
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "runtime branch mirror is unavailable");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    if (sequence_id == 0) {
+        llama_memory_seq_rm(memory, mirror_id, commit_end, -1);
+    } else {
+        llama_memory_seq_rm(memory, mirror_id, -1, -1);
+        llama_memory_seq_cp(memory, physical_id, mirror_id, 0, commit_end);
+    }
+    for (uint32_t logical_id = 1; logical_id < session->pending_branch_count; ++logical_id) {
+        const llama_seq_id discarded_id = skippy_branch_sequence_id(session, logical_id);
+        if (discarded_id >= 0) {
+            llama_memory_seq_rm(memory, discarded_id, -1, -1);
+        }
+    }
+    session->pending_branch_count = 0;
+    session->pending_branch_max_pos.clear();
+    session->branch_mirror_valid = true;
