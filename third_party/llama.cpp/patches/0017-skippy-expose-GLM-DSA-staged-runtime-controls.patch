+        case SKIPPY_GLM_DSA_OP_ROUTED_MOE_AGGREGATE:
+            return "routed_moe_aggregate";
+        case SKIPPY_GLM_DSA_OP_SHARED_EXPERT:
+            return "shared_expert";
+        case SKIPPY_GLM_DSA_OP_COUNT:
+        case SKIPPY_GLM_DSA_OP_UNKNOWN:
+            break;
+    }
+    return "unknown";
+}
