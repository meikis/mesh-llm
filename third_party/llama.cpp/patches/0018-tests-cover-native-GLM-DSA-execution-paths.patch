+            ggml_tensor * anchor = ggml_scale(ctx, ggml_sum(ctx, out), 0.0f);
+            anchor = ggml_repeat(ctx, anchor, cur);
+            cur = ggml_add(ctx, cur, anchor);
+            ggml_format_name(cur, "projection_chain_cur_%d", repeat);
