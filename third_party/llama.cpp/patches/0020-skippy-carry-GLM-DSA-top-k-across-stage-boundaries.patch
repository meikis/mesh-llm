 static bool skippy_is_filtered(const skippy_session * session) {
     return session != nullptr &&
            session->stage_model != nullptr &&
@@ -1095,6 +1126,74 @@ static bool skippy_is_gemma3n_activation_model(const skippy_session * session) {
     return session->stage_model->model->arch == LLM_ARCH_GEMMA3N;
 }
 
+static bool skippy_is_glm_dsa_activation_model(const skippy_session * session) {
+    return session != nullptr &&
+           session->stage_model != nullptr &&
+           session->stage_model->model != nullptr &&
+           session->stage_model->model->arch == LLM_ARCH_GLM_DSA;
+}
+
+static bool skippy_glm_dsa_layer_is_shared(const skippy_session * session, int32_t layer_index) {
+    if (!skippy_is_glm_dsa_activation_model(session)) {
+        return false;
+    }
+    const llama_hparams & hparams = session->stage_model->model->hparams;
+    return layer_index > 0 &&
+           static_cast<uint32_t>(layer_index) < hparams.n_layer() &&
+           !hparams.is_indexer_full(layer_index);
+}
+
+static bool skippy_glm_dsa_stage_starts_shared(const skippy_session * session) {
+    return skippy_is_filtered(session) &&
+           skippy_glm_dsa_layer_is_shared(session, session->stage_model->config.layer_start);
+}
+
+static uint32_t skippy_glm_dsa_padded_top_k_count(const skippy_session * session, uint64_t n_kv) {
+    if (!skippy_is_glm_dsa_activation_model(session)) {
+        return 0;
+    }
+    const uint64_t padded_n_kv = std::max<uint64_t>(256, GGML_PAD(n_kv, 256));
+    return static_cast<uint32_t>(
+            std::min<uint64_t>(padded_n_kv, session->stage_model->model->hparams.indexer_top_k));
+}
+
+static uint32_t skippy_glm_dsa_visible_top_k_count(const skippy_session * session, uint64_t n_kv) {
+    if (!skippy_is_glm_dsa_activation_model(session)) {
+        return 0;
+    }
+    return static_cast<uint32_t>(
+            std::min<uint64_t>(n_kv, session->stage_model->model->hparams.indexer_top_k));
+}
+
+static size_t skippy_glm_dsa_top_k_bytes(const skippy_session * session, size_t token_count) {
+    const uint64_t n_kv = static_cast<uint64_t>(std::max<int32_t>(session->n_past, 0)) + token_count;
+    return static_cast<size_t>(skippy_glm_dsa_padded_top_k_count(session, n_kv))*token_count*sizeof(int32_t);
+}
+
+static uint32_t skippy_glm_dsa_top_k_count_from_desc(
+        const skippy_session * session,
+        const skippy_activation_desc * desc) {
+    if (desc == nullptr ||
+        desc->token_count == 0 ||
+        (desc->flags & SKIPPY_ACTIVATION_FLAG_GLM_DSA_TOP_K) == 0) {
+        return 0;
+    }
+    const size_t hidden_bytes =
+            static_cast<size_t>(desc->token_count)*
+            static_cast<size_t>(llama_model_n_embd(session->stage_model->model))*
+            sizeof(float);
+    if (desc->payload_bytes <= hidden_bytes) {
+        return 0;
+    }
+    const size_t sideband_bytes = static_cast<size_t>(desc->payload_bytes - hidden_bytes);
+    const size_t row_bytes = sideband_bytes/desc->token_count;
+    if (sideband_bytes % desc->token_count != 0 || row_bytes % sizeof(int32_t) != 0) {
+        return 0;
+    }
+    const size_t n_top_k = row_bytes/sizeof(int32_t);
+    return n_top_k <= std::numeric_limits<uint32_t>::max() ? static_cast<uint32_t>(n_top_k) : 0;
+}
