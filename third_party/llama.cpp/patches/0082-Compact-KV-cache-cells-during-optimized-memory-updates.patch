 llama_memory_context_ptr llama_kv_cache::init_update(llama_context * lctx, bool optimize) {
-    GGML_UNUSED(optimize);
-
     bool do_shift = get_has_shift();
+    bool did_compact = false;
+
+    if (optimize) {
+        if (lctx != nullptr) {
