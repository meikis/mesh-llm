From 7257d40a90e46a353d9f2aa7dfa423d3dd17e7bf Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Wed, 17 Jun 2026 19:09:05 +1000
Subject: [PATCH] Allow multi-generation stage checkpoint restores

---
 src/skippy.cpp | 173 +++++++++++++++++++++++++++++++++++--------------
 1 file changed, 126 insertions(+), 47 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index d3aea60b..a8be71bc 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -52,6 +52,15 @@ struct skippy_model {
     std::vector<std::vector<llama_token>> lane_resident_prefix_tokens;
 };
 
+static constexpr int32_t SKIPPY_CHECKPOINT_SLOTS_PER_LANE = 8;
+
+struct skippy_session_checkpoint_slot {
+    bool valid = false;
+    int32_t n_past = 0;
+    size_t token_history_size = 0;
+    size_t signal_history_size = 0;
+};
+
 struct skippy_session {
     skippy_model * stage_model = nullptr;
     llama_context * ctx = nullptr;
@@ -66,6 +75,7 @@ struct skippy_session {
     int32_t checkpoint_n_past = 0;
     size_t checkpoint_token_history_size = 0;
     size_t checkpoint_signal_history_size = 0;
+    skippy_session_checkpoint_slot checkpoint_slots[SKIPPY_CHECKPOINT_SLOTS_PER_LANE];
     std::vector<llama_token> token_history;
     std::vector<skippy_token_signal> signal_history;
     llama_sampler * sampling_chain = nullptr;
@@ -75,6 +85,12 @@ struct skippy_session {
     size_t sampling_accepted_token_count = 0;
 };
 
+static int32_t skippy_reserved_sequence_count(uint32_t lane_count);
+static size_t skippy_checkpoint_slot_for_token_count(uint64_t token_count);
+static int32_t skippy_checkpoint_sequence_id(const skippy_session * session, size_t slot);
+static void skippy_clear_checkpoint_slots(skippy_session * session);
+static void skippy_drop_checkpoint_sequences(skippy_session * session, llama_memory_t memory);
+
 struct skippy_tensor_meta {
     std::string name;
     int32_t layer_index = -1;
@@ -2301,7 +2317,10 @@ static enum skippy_status skippy_finish_model_open(
     params.flash_attn_type = config != nullptr ? static_cast<llama_flash_attn_type>(config->flash_attn_type) : LLAMA_FLASH_ATTN_TYPE_AUTO;
     params.embeddings = config != nullptr && config->filter_tensors_on_load && !config->include_output;
     if (llm_arch_is_recurrent(model->arch) || llm_arch_is_hybrid(model->arch)) {
-        params.n_seq_max = std::max<uint32_t>(2, stage_model->lane_count * 2);
+        params.n_seq_max = std::max<uint32_t>(
+                2,
+                static_cast<uint32_t>(skippy_reserved_sequence_count(stage_model->lane_count)));
+        params.n_outputs_max = std::max<uint32_t>(params.n_outputs_max, params.n_seq_max);
         params.kv_unified = true;
     }
 
@@ -2574,18 +2592,18 @@ enum skippy_status skippy_session_create(
     session->stage_model = model;
     session->ctx = model->ctx;
     session->seq_id = seq_id;
-    session->checkpoint_seq_id = seq_id + static_cast<int32_t>(model->lane_count);
+    session->checkpoint_seq_id = skippy_checkpoint_sequence_id(session, 0);
     session->borrowed_sequence = false;
     session->borrowed_prefix_tokens = 0;
     session->n_past = 0;
-    session->checkpoint_valid = false;
-    session->checkpoint_n_past = 0;
+    skippy_clear_checkpoint_slots(session);
     *out_session = session;
     if (static_cast<size_t>(seq_id) < model->lane_resident_prefix_tokens.size()) {
         model->lane_resident_prefix_tokens[static_cast<size_t>(seq_id)].clear();
     }
     if (llama_memory_t memory = model->ctx->get_memory()) {
         llama_memory_seq_rm(memory, seq_id, -1, -1);
+        skippy_drop_checkpoint_sequences(session, memory);
     }
     return skippy_success(out_error);
 }
@@ -2742,11 +2760,10 @@ enum skippy_status skippy_session_reset(
         return SKIPPY_STATUS_RUNTIME_ERROR;
     }
     if (!session->borrowed_sequence) {
-        llama_memory_seq_rm(memory, session->checkpoint_seq_id, -1, -1);
+        skippy_drop_checkpoint_sequences(session, memory);
     }
     session->n_past = session->borrowed_sequence ? session->borrowed_prefix_tokens : 0;
-    session->checkpoint_valid = false;
-    session->checkpoint_n_past = 0;
+    skippy_clear_checkpoint_slots(session);
     if (session->borrowed_sequence) {
         if (session->token_history.size() > static_cast<size_t>(session->borrowed_prefix_tokens)) {
             session->token_history.resize(static_cast<size_t>(session->borrowed_prefix_tokens));
@@ -2773,7 +2790,7 @@ enum skippy_status skippy_session_free(
                             session->seq_id,
                             static_cast<llama_pos>(session->preserve_prefix_tokens),
                             -1);
-                    llama_memory_seq_rm(memory, session->checkpoint_seq_id, -1, -1);
+                    skippy_drop_checkpoint_sequences(session, memory);
                 }
                 session->ctx->synchronize();
             } else {
@@ -3412,7 +3429,7 @@ static void skippy_update_session_state_after_import(
     if (session->signal_history.size() > static_cast<size_t>(session->n_past)) {
         session->signal_history.resize(static_cast<size_t>(session->n_past));
     }
-    session->checkpoint_valid = false;
+    skippy_clear_checkpoint_slots(session);
 }
 
 enum skippy_status skippy_export_state(
@@ -3880,14 +3897,57 @@ enum skippy_status skippy_trim_session(
     return skippy_success(out_error);
 }
 
+static int32_t skippy_reserved_sequence_count(
+        uint32_t lane_count) {
+    return static_cast<int32_t>(lane_count) * (1 + SKIPPY_CHECKPOINT_SLOTS_PER_LANE);
+}
+
+static size_t skippy_checkpoint_slot_for_token_count(
+        uint64_t token_count) {
+    return static_cast<size_t>(token_count % SKIPPY_CHECKPOINT_SLOTS_PER_LANE);
+}
+
+static int32_t skippy_checkpoint_sequence_id(
+        const skippy_session * session,
+        size_t slot) {
+    return static_cast<int32_t>(session->stage_model->lane_count)
+        + session->seq_id * SKIPPY_CHECKPOINT_SLOTS_PER_LANE
+        + static_cast<int32_t>(slot);
+}
+
+static void skippy_clear_checkpoint_slots(
+        skippy_session * session) {
+    if (session == nullptr) {
+        return;
+    }
+    for (auto & slot : session->checkpoint_slots) {
+        slot = {};
+    }
+    session->checkpoint_valid = false;
+    session->checkpoint_n_past = 0;
+    session->checkpoint_token_history_size = 0;
+    session->checkpoint_signal_history_size = 0;
+}
+
+static void skippy_drop_checkpoint_sequences(
+        skippy_session * session,
+        llama_memory_t memory) {
+    if (session == nullptr || session->stage_model == nullptr || memory == nullptr) {
+        return;
+    }
+    for (size_t slot = 0; slot < SKIPPY_CHECKPOINT_SLOTS_PER_LANE; ++slot) {
+        llama_memory_seq_rm(memory, skippy_checkpoint_sequence_id(session, slot), -1, -1);
+    }
+    skippy_clear_checkpoint_slots(session);
+}
+
 static bool skippy_is_reserved_sequence_id(
         const skippy_session * session,
         int32_t seq_id) {
     if (session == nullptr || session->stage_model == nullptr || seq_id < 0) {
         return true;
     }
-    const int32_t reserved = static_cast<int32_t>(session->stage_model->lane_count) * 2;
-    return seq_id < reserved;
+    return seq_id < skippy_reserved_sequence_count(session->stage_model->lane_count);
 }
 
 static bool skippy_is_reserved_sequence_id_for_model(
@@ -3896,8 +3956,7 @@ static bool skippy_is_reserved_sequence_id_for_model(
     if (model == nullptr || seq_id < 0) {
         return true;
     }
-    const int32_t reserved = static_cast<int32_t>(model->lane_count) * 2;
-    return seq_id < reserved;
+    return seq_id < skippy_reserved_sequence_count(model->lane_count);
 }
 
 static enum skippy_status skippy_get_resident_prefix_memory(
@@ -4026,10 +4085,7 @@ enum skippy_status skippy_session_restore_prefix(
         session->token_history.assign(token_ids, token_ids + token_count);
     }
     session->signal_history.clear();
-    session->checkpoint_valid = false;
-    session->checkpoint_n_past = 0;
-    session->checkpoint_token_history_size = 0;
-    session->checkpoint_signal_history_size = 0;
+    skippy_drop_checkpoint_sequences(session, memory);
     session->ctx->synchronize();
     return skippy_success(out_error);
 }
@@ -4119,12 +4175,11 @@ enum skippy_status skippy_session_create_from_resident_prefix(
     session->stage_model = model;
     session->ctx = model->ctx;
     session->seq_id = seq_id;
-    session->checkpoint_seq_id = seq_id + static_cast<int32_t>(model->lane_count);
+    session->checkpoint_seq_id = skippy_checkpoint_sequence_id(session, 0);
     session->n_past = static_cast<int32_t>(token_count);
     session->borrowed_sequence = false;
     session->borrowed_prefix_tokens = 0;
-    session->checkpoint_valid = false;
-    session->checkpoint_n_past = 0;
+    skippy_clear_checkpoint_slots(session);
     if (token_count > 0) {
         session->token_history.assign(token_ids, token_ids + token_count);
     }
@@ -4176,18 +4231,28 @@ enum skippy_status skippy_checkpoint_session(
         }
         return out_error != nullptr && *out_error != nullptr ? (*out_error)->status : SKIPPY_STATUS_RUNTIME_ERROR;
     }
+    const size_t checkpoint_slot = skippy_checkpoint_slot_for_token_count(static_cast<uint64_t>(session->n_past));
+    const int32_t checkpoint_seq_id = skippy_checkpoint_sequence_id(session, checkpoint_slot);
     if (recurrent != nullptr) {
-        if (llama_n_seq_max(session->ctx) < 2) {
-            skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "native recurrent checkpoint requires n_seq_max >= 2");
+        const uint32_t seq_max = llama_n_seq_max(session->ctx);
+        if (checkpoint_seq_id < 0 || static_cast<uint32_t>(checkpoint_seq_id) >= seq_max) {
+            skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "native recurrent checkpoint slot exceeds n_seq_max");
             return SKIPPY_STATUS_UNSUPPORTED;
         }
-        recurrent->seq_cp(session->seq_id, session->checkpoint_seq_id, -1, -1);
+        recurrent->seq_rm(checkpoint_seq_id, -1, -1);
+        recurrent->seq_cp(session->seq_id, checkpoint_seq_id, -1, -1);
     }
 
+    auto & slot = session->checkpoint_slots[checkpoint_slot];
+    slot.valid = true;
+    slot.n_past = session->n_past;
+    slot.token_history_size = session->token_history.size();
+    slot.signal_history_size = session->signal_history.size();
     session->checkpoint_valid = true;
     session->checkpoint_n_past = session->n_past;
-    session->checkpoint_token_history_size = session->token_history.size();
-    session->checkpoint_signal_history_size = session->signal_history.size();
+    session->checkpoint_token_history_size = slot.token_history_size;
+    session->checkpoint_signal_history_size = slot.signal_history_size;
+    session->checkpoint_seq_id = checkpoint_seq_id;
     *out_token_count = static_cast<uint64_t>(session->n_past);
     return skippy_success(out_error);
 }
@@ -4200,11 +4265,33 @@ enum skippy_status skippy_restore_session_checkpoint(
         skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session is required");
         return SKIPPY_STATUS_INVALID_ARGUMENT;
     }
-    if (!session->checkpoint_valid) {
+
+    skippy_error * recurrent_error = nullptr;
+    llama_memory_recurrent * recurrent = skippy_get_recurrent_memory(session, &recurrent_error);
+    if (recurrent_error != nullptr) {
+        if (out_error != nullptr) {
+            *out_error = recurrent_error;
+        } else {
+            skippy_error_free(recurrent_error);
+        }
+        return out_error != nullptr && *out_error != nullptr ? (*out_error)->status : SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    if (recurrent == nullptr) {
+        enum skippy_status status = skippy_trim_session(session, token_count, out_error);
+        if (status != SKIPPY_STATUS_OK) {
+            return status;
+        }
+        skippy_clear_checkpoint_slots(session);
+        return skippy_success(out_error);
+    }
+
+    const size_t checkpoint_slot = skippy_checkpoint_slot_for_token_count(token_count);
+    const auto & slot = session->checkpoint_slots[checkpoint_slot];
+    if (!slot.valid) {
         skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session checkpoint is not available");
         return SKIPPY_STATUS_INVALID_ARGUMENT;
     }
-    if (token_count != static_cast<uint64_t>(session->checkpoint_n_past)) {
+    if (token_count != static_cast<uint64_t>(slot.n_past)) {
         skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session checkpoint token count mismatch");
         return SKIPPY_STATUS_INVALID_ARGUMENT;
     }
@@ -4214,34 +4301,26 @@ enum skippy_status skippy_restore_session_checkpoint(
         return status;
     }
 
-    skippy_error * recurrent_error = nullptr;
-    llama_memory_recurrent * recurrent = skippy_get_recurrent_memory(session, &recurrent_error);
-    if (recurrent_error != nullptr) {
-        if (out_error != nullptr) {
-            *out_error = recurrent_error;
-        } else {
-            skippy_error_free(recurrent_error);
-        }
-        return out_error != nullptr && *out_error != nullptr ? (*out_error)->status : SKIPPY_STATUS_RUNTIME_ERROR;
-    }
     if (recurrent != nullptr) {
-        if (llama_n_seq_max(session->ctx) < 2) {
-            skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "native recurrent checkpoint requires n_seq_max >= 2");
+        const int32_t checkpoint_seq_id = skippy_checkpoint_sequence_id(session, checkpoint_slot);
+        const uint32_t seq_max = llama_n_seq_max(session->ctx);
+        if (checkpoint_seq_id < 0 || static_cast<uint32_t>(checkpoint_seq_id) >= seq_max) {
+            skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "native recurrent checkpoint slot exceeds n_seq_max");
             return SKIPPY_STATUS_UNSUPPORTED;
         }
-        recurrent->seq_cp(session->checkpoint_seq_id, session->seq_id, -1, -1);
-        recurrent->seq_rm(session->checkpoint_seq_id, -1, -1);
+        recurrent->seq_cp(checkpoint_seq_id, session->seq_id, -1, -1);
+        recurrent->seq_rm(checkpoint_seq_id, -1, -1);
         session->ctx->synchronize();
     }
 
-    session->n_past = session->checkpoint_n_past;
-    if (session->token_history.size() > session->checkpoint_token_history_size) {
-        session->token_history.resize(session->checkpoint_token_history_size);
+    session->n_past = slot.n_past;
+    if (session->token_history.size() > slot.token_history_size) {
+        session->token_history.resize(slot.token_history_size);
     }
-    if (session->signal_history.size() > session->checkpoint_signal_history_size) {
-        session->signal_history.resize(session->checkpoint_signal_history_size);
+    if (session->signal_history.size() > slot.signal_history_size) {
+        session->signal_history.resize(slot.signal_history_size);
     }
-    session->checkpoint_valid = false;
+    skippy_clear_checkpoint_slots(session);
     return skippy_success(out_error);
 }
 
-- 
