+        if (!timing.hot_tensors[i].used || elapsed_us > timing.hot_tensors[i].elapsed_us) {
+            slot = i;
+            break;
+        }
+    }
+    if (slot == SKIPPY_GLM_DSA_HOT_TENSOR_LIMIT) {
+        return;
+    }
