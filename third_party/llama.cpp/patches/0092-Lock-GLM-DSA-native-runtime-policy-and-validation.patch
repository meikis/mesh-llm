+struct glm_dsa_graph_op_counts {
+    int total             = 0;
+    int lightning_indexer = 0;
+    int top_k             = 0;
+    int top_k_consumers   = 0;
+    int compact_get_rows  = 0;
+    int flash_attn        = 0;
+    int sparse_mask       = 0;
+    int sparse_mask_nodes = 0;
+    int dsa_sparse_attn   = 0;
+    int64_t max_top_k_width = 0;
+    int64_t max_compact_rows = 0;
+};
