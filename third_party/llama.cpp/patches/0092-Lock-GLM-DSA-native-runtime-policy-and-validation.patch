+        view->ne[0] == 512 &&
+        q->ne[1] == 1 &&
+        rows->src[0]->ne[2] == 1 &&
+        view->ne[2] == 1 &&
+        rows->src[0]->ne[3] == 1 &&
+        view->ne[3] == 1;
