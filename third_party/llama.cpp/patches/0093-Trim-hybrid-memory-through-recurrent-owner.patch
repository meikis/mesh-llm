From 18a345df4d7562c825361e4fbc812470a24d45c6 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Wed, 17 Jun 2026 22:30:00 +1000
Subject: [PATCH] Trim hybrid memory through recurrent owner

---
 src/skippy.cpp | 10 ++++------
 1 file changed, 4 insertions(+), 6 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index ee554e1f..10ae3ba1 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -3864,15 +3865,13 @@ enum skippy_status skippy_trim_session(
     }
     const llama_pos p0 = static_cast<llama_pos>(token_count);
     if (auto * hybrid = dynamic_cast<llama_memory_hybrid *>(memory)) {
-        llama_kv_cache * kv = hybrid->get_mem_attn();
-        if (kv != nullptr && !kv->seq_rm(session->seq_id, p0, -1)) {
-            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid attention KV suffix");
+        if (!hybrid->seq_rm(session->seq_id, p0, -1)) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid memory suffix");
             return SKIPPY_STATUS_RUNTIME_ERROR;
         }
     } else if (auto * hybrid_iswa = dynamic_cast<llama_memory_hybrid_iswa *>(memory)) {
-        llama_kv_cache_iswa * kv = hybrid_iswa->get_mem_attn();
-        if (kv != nullptr && !kv->seq_rm(session->seq_id, p0, -1)) {
-            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid ISWA attention KV suffix");
+        if (!hybrid_iswa->seq_rm(session->seq_id, p0, -1)) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid ISWA memory suffix");
             return SKIPPY_STATUS_RUNTIME_ERROR;
         }
     } else if (auto * kv = dynamic_cast<llama_kv_cache *>(memory)) {
