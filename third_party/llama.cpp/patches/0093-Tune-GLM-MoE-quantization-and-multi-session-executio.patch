+
+find_binary() {
+    local name="$1"
+    shift
+    for candidate in "$@"; do
+        if [[ -x "${candidate}/${name}" ]]; then
+            printf '%s\n' "${candidate}/${name}"
+            return 0
+        fi
+    done
+    return 1
+}
+
