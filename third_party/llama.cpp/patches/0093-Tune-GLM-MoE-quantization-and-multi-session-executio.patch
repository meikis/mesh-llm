+static int ggml_metal_op_mul_mv_id_gate_up_swiglu(ggml_metal_op_t ctx, int idx) {
+    ggml_metal_mul_mv_id_gate_up_swiglu_fusion fusion;
+    if (!ggml_metal_match_mul_mv_id_gate_up_swiglu(ctx, idx, fusion)) {
+        return 0;
+    }
+
+    ggml_tensor * up = fusion.up;
+    ggml_tensor * gate = fusion.gate;
+    ggml_tensor * glu = fusion.glu;
+
+    ggml_metal_library_t lib = ctx->lib;
+    ggml_metal_encoder_t enc = ctx->enc;
+
+    GGML_TENSOR_LOCALS( int32_t, ne0, up->src[0], ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb0, up->src[0], nb);
+    GGML_TENSOR_LOCALS( int32_t, ne1, up->src[1], ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb1, up->src[1], nb);
+    GGML_TENSOR_LOCALS( int32_t, ne2, up->src[2], ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb2, up->src[2], nb);
+    GGML_TENSOR_LOCALS( int32_t, ne,  glu,        ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb,  glu,        nb);
+
+    auto pipeline = ggml_metal_library_get_pipeline_mul_mv_id_gate_up_swiglu(lib, glu);
+    const int nr0 = pipeline.nr0;
+    const int nr1 = pipeline.nr1;
+    const int nsg = pipeline.nsg;
+
+    ggml_metal_kargs_mul_mv_id_gate_up_swiglu args = {
+        /*.nei0 =*/ ne20,
+        /*.nei1 =*/ ne21,
+        /*.nbi1 =*/ nb21,
+        /*.ne00 =*/ ne00,
+        /*.ne01 =*/ ne01,
+        /*.ne02 =*/ ne02,
+        /*.nb00 =*/ nb00,
+        /*.nb01 =*/ nb01,
+        /*.nb02 =*/ nb02,
+        /*.ne10 =*/ ne10,
+        /*.ne11 =*/ ne11,
+        /*.ne12 =*/ ne12,
+        /*.ne13 =*/ ne13,
+        /*.nb10 =*/ nb10,
+        /*.nb11 =*/ nb11,
+        /*.nb12 =*/ nb12,
+        /*.ne0  =*/ ne0,
+        /*.ne1  =*/ ne1,
+        /*.nb1  =*/ nb1,
+        /*.nr0  =*/ nr0,
+    };
+
+    ggml_metal_op_concurrency_reset(ctx);
+
+    ggml_metal_encoder_set_pipeline(enc, pipeline);
+    ggml_metal_encoder_set_bytes(enc, &args, sizeof(args), 0);
+    ggml_metal_encoder_set_buffer(enc, ggml_metal_get_buffer_id(up->src[0]),   1);
+    ggml_metal_encoder_set_buffer(enc, ggml_metal_get_buffer_id(gate->src[0]), 2);
+    ggml_metal_encoder_set_buffer(enc, ggml_metal_get_buffer_id(up->src[1]),   3);
+    ggml_metal_encoder_set_buffer(enc, ggml_metal_get_buffer_id(glu),          4);
+    ggml_metal_encoder_set_buffer(enc, ggml_metal_get_buffer_id(up->src[2]),   5);
+
+    const int64_t ne123 = ne20*ne21;
+    const int grid_x = (ne01 + nr0*nsg - 1)/(nr0*nsg);
+    const int grid_y = (1 + nr1 - 1)/nr1;
+    const int grid_z = ne123;
+
+    ggml_metal_encoder_set_threadgroup_memory_size(enc, pipeline.smem, 0);
+    ggml_metal_encoder_dispatch_threadgroups(enc, grid_x, grid_y, grid_z, 32, nsg, 1);
+
+    if (ggml_metal_glm_dsa_dispatch_log_enabled()) {
+        GGML_LOG_INFO(
+            "skippy: glm_dsa_metal_dispatch op=mul_mv_id_q2_gate_up_swiglu tensor=%s up=%s gate=%s src0_type=%s src1_type=%s ids_type=%s dst_type=%s ne00=%d ne01=%d experts=%d used_experts=%d tokens=%d nr0=%d nr1=%d nsg=%d grid_x=%d grid_y=%d grid_z=%d threads_x=%d threads_y=%d fused_nodes=%d\n",
+            ggml_metal_tensor_name(glu),
+            ggml_metal_tensor_name(up),
+            ggml_metal_tensor_name(gate),
+            ggml_type_name(up->src[0]->type),
+            ggml_type_name(up->src[1]->type),
+            ggml_type_name(up->src[2]->type),
+            ggml_type_name(glu->type),
+            ne00,
+            ne01,
+            ne02,
+            ne20,
+            ne21,
+            nr0,
+            nr1,
+            nsg,
+            grid_x,
+            grid_y,
+            grid_z,
+            32,
+            nsg,
+            fusion.n_fuse);
+    }
+
+    return fusion.n_fuse;
+}
