From 3f6f6f4d8a66a2fd6fe2f2cb9bd0581bb4c59094 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Wed, 17 Jun 2026 23:45:00 +1000
Subject: [PATCH] Restore hybrid checkpoints without recurrent trim

Hybrid checkpoint restore already restores recurrent state from the checkpoint
sequence. Trimming the hybrid wrapper first also asks the recurrent memory to
roll back the speculative suffix, which can fail when the suffix is longer than
the recurrent rollback window. For checkpoint restore, trim only the attention
KV suffix and then copy the saved recurrent checkpoint back into the execution
sequence.
---
 src/skippy.cpp | 59 ++++++++++++++++++++++++++++++++++++++++++++++++---
 1 file changed, 56 insertions(+), 3 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 10ae3ba1..2f905efc 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -3896,6 +3896,59 @@ enum skippy_status skippy_trim_session(
     return skippy_success(out_error);
 }
 
+static enum skippy_status skippy_trim_session_for_checkpoint_restore(
+        struct skippy_session * session,
+        uint64_t token_count,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->ctx == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (token_count > static_cast<uint64_t>(std::numeric_limits<int32_t>::max())) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "token_count exceeds int32_t range");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (token_count > static_cast<uint64_t>(session->n_past)) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "cannot trim session beyond current token count");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    session->ctx->synchronize();
+    llama_memory_t memory = session->ctx->get_memory();
+    if (memory == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "runtime memory is unavailable");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+
+    const llama_pos p0 = static_cast<llama_pos>(token_count);
+    if (auto * hybrid = dynamic_cast<llama_memory_hybrid *>(memory)) {
+        llama_kv_cache * kv = hybrid->get_mem_attn();
+        if (kv != nullptr && !kv->seq_rm(session->seq_id, p0, -1)) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid attention KV suffix");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+    } else if (auto * hybrid_iswa = dynamic_cast<llama_memory_hybrid_iswa *>(memory)) {
+        llama_kv_cache_iswa * kv = hybrid_iswa->get_mem_attn();
+        if (kv != nullptr && !kv->seq_rm(session->seq_id, p0, -1)) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to trim hybrid ISWA attention KV suffix");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+    } else {
+        return skippy_trim_session(session, token_count, out_error);
+    }
+
+    session->n_past = static_cast<int32_t>(token_count);
+    if (session->token_history.size() > token_count) {
+        session->token_history.resize(static_cast<size_t>(token_count));
+        skippy_clear_chat_sampling(session);
+    }
+    if (session->signal_history.size() > token_count) {
+        session->signal_history.resize(static_cast<size_t>(token_count));
+    }
+    session->ctx->synchronize();
+    return skippy_success(out_error);
+}
+
 static int32_t skippy_reserved_sequence_count(
         uint32_t lane_count) {
     return static_cast<int32_t>(lane_count) * (1 + SKIPPY_CHECKPOINT_SLOTS_PER_LANE);
@@ -4295,9 +4347,9 @@ enum skippy_status skippy_restore_session_checkpoint(
         return SKIPPY_STATUS_INVALID_ARGUMENT;
     }
 
-    enum skippy_status status = skippy_trim_session(session, token_count, out_error);
-    if (status != SKIPPY_STATUS_OK) {
-        return status;
+    enum skippy_status trim_status = skippy_trim_session_for_checkpoint_restore(session, token_count, out_error);
+    if (trim_status != SKIPPY_STATUS_OK) {
+        return trim_status;
     }
 
     if (recurrent != nullptr) {
