From 0b7c9d55c939fb64020d1221bf9b8efe1824ee0c Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Mon, 15 Jun 2026 23:59:00 +1000
Subject: [PATCH] Include native MTP tensors in final runtime slices

---
 src/skippy.cpp | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 213619e6..4d15b320 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -884,6 +884,9 @@ struct skippy_filter_scope {
             filter.enabled = true;
             filter.layer_start = config->layer_start;
             filter.layer_end = config->layer_end;
+            if (config->include_output && filter.layer_end < std::numeric_limits<int32_t>::max()) {
+                filter.layer_end += 1;
+            }
             filter.include_embeddings = config->include_embeddings;
             filter.include_output = config->include_output;
             llama_model_loader_set_stage_filter(filter);
