From d827525b1537c17836787239526b348e9bfb5edc Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 10:30:54 +1000
Subject: [PATCH] Correlate GLM route scheduler and execution logs

---
 ggml/src/ggml-backend.cpp              |  3 ++-
 ggml/src/ggml-metal/ggml-metal-ops.cpp | 22 ++++++++++++++++++++--
 2 files changed, 22 insertions(+), 3 deletions(-)

diff --git a/ggml/src/ggml-backend.cpp b/ggml/src/ggml-backend.cpp
index 854dc4f24..164ba0ede 100644
--- a/ggml/src/ggml-backend.cpp
+++ b/ggml/src/ggml-backend.cpp
@@ -1052,8 +1052,9 @@ static void ggml_backend_sched_log_glm_route_splits(ggml_backend_sched_t sched,
         }
 
         GGML_LOG_INFO(
-                "skippy: glm_dsa_metal_dispatch op=topk_moe_route_sched tensor=%s split_start=%d split_end=%d split_count=%d candidate=%s grid_x=1 grid_y=1 grid_z=1 threads_x=1\n",
+                "skippy: glm_dsa_metal_dispatch op=topk_moe_route_sched tensor=%s graph_uid=%llu split_start=%d split_end=%d split_count=%d candidate=%s grid_x=1 grid_y=1 grid_z=1 threads_x=1\n",
                 node->name,
+                (unsigned long long) graph->uid,
                 first_split,
                 last_split,
                 split_count,
diff --git a/ggml/src/ggml-metal/ggml-metal-ops.cpp b/ggml/src/ggml-metal/ggml-metal-ops.cpp
index 23c6fc8e2..3c460d75b 100644
--- a/ggml/src/ggml-metal/ggml-metal-ops.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-ops.cpp
@@ -182,6 +182,18 @@ struct ggml_metal_op {
         return gf->n_nodes;
     }
 
+    uint64_t graph_uid() const {
+        return gf->uid;
+    }
+
+    int split_start() const {
+        return idx_start;
+    }
+
+    int split_end() const {
+        return idx_end;
+    }
+
     ggml_tensor * graph_node(int i) const {
         assert(i >= 0 && i < gf->n_nodes);
         return ggml_graph_node(gf, i);
@@ -342,10 +354,13 @@ static void ggml_metal_log_topk_moe_route_encode_candidate(ggml_metal_op_t ctx,
     }
 
     GGML_LOG_INFO(
-            "skippy: glm_dsa_metal_dispatch op=topk_moe_route_encode tensor=%s candidate=%s reason=%s filtered_nodes=%d graph_nodes=%d graph_idx=%d grid_x=1 grid_y=1 grid_z=1 threads_x=1\n",
+            "skippy: glm_dsa_metal_dispatch op=topk_moe_route_encode tensor=%s candidate=%s reason=%s graph_uid=%llu split_start=%d split_end=%d filtered_nodes=%d graph_nodes=%d graph_idx=%d grid_x=1 grid_y=1 grid_z=1 threads_x=1\n",
             ggml_metal_tensor_name(node),
             ops,
             reason,
+            (unsigned long long) ctx->graph_uid(),
+            ctx->split_start(),
+            ctx->split_end(),
             ctx->n_nodes(),
             ctx->graph_node_count(),
             ctx->graph_index(idx));
@@ -520,11 +535,14 @@ static int ggml_metal_op_topk_moe_route_fused(ggml_metal_op_t ctx, int idx) {
     const int nth = 1;
     if (ggml_metal_glm_dsa_dispatch_log_enabled()) {
         GGML_LOG_INFO(
-            "skippy: glm_dsa_metal_dispatch op=topk_moe_route_fused tensor=%s logits=%s ids=%s weights=%s experts=%d tokens=%d top_k=%d fused_nodes=%d scale=%g grid_x=%d grid_y=1 grid_z=1 threads_x=%d\n",
+            "skippy: glm_dsa_metal_dispatch op=topk_moe_route_fused tensor=%s logits=%s ids=%s weights=%s graph_uid=%llu split_start=%d split_end=%d experts=%d tokens=%d top_k=%d fused_nodes=%d scale=%g grid_x=%d grid_y=1 grid_z=1 threads_x=%d\n",
             ggml_metal_tensor_name(ctx->node(idx)),
             ggml_metal_tensor_name(fusion.logits),
             ggml_metal_tensor_name(fusion.ids),
             ggml_metal_tensor_name(fusion.weights),
+            (unsigned long long) ctx->graph_uid(),
+            ctx->split_start(),
+            ctx->split_end(),
             args.n_expert,
             args.n_tokens,
             args.top_k,
-- 
2.53.0

