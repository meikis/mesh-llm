From d21ba4bc28637d71fa0190c56e3c9ab8c2edbd85 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 13:31:24 +1000
Subject: [PATCH] Enable GLM MoE route weights by default

---
 src/llama-graph.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index fa755985d..70ca4f017 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -111,7 +111,12 @@ static bool skippy_glm_dsa_moe_weighted_sum_enabled() {
 }
 
 static bool skippy_glm_dsa_moe_route_weights_enabled() {
-    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_MOE_ROUTE_WEIGHTS");
+    if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_MOE_ROUTE_WEIGHTS") ||
+        skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_MOE_ROUTE_WEIGHTS")) {
+        return false;
+    }
+
+    return true;
 }
 
 static bool skippy_glm_dsa_moe_top_k_enabled() {
