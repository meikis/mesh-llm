From e89bc27e850050b208d0ec94aa2e265708ced881 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 15:02:14 +1000
Subject: [PATCH] Clarify GLM DSA sparse policy diagnostics

---
 src/skippy.cpp | 34 ++++++++++++++++++++++++++++++++--
 1 file changed, 32 insertions(+), 2 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 82c68831e..3397f6839 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1633,6 +1633,20 @@ static bool skippy_env_enabled(const char * name) {
            std::strcmp(value, "no") != 0;
 }
 
+static bool skippy_env_disabled(const char * name) {
+    const char * value = std::getenv(name);
+    if (value == nullptr || value[0] == '\0') {
+        return false;
+    }
+    return std::strcmp(value, "0") == 0 ||
+           std::strcmp(value, "false") == 0 ||
+           std::strcmp(value, "FALSE") == 0 ||
+           std::strcmp(value, "off") == 0 ||
+           std::strcmp(value, "OFF") == 0 ||
+           std::strcmp(value, "no") == 0 ||
+           std::strcmp(value, "NO") == 0;
+}
+
 static uint32_t skippy_env_u32(const char * name, uint32_t fallback, uint32_t min_value, uint32_t max_value) {
     const char * value = std::getenv(name);
     if (value == nullptr || value[0] == '\0') {
@@ -1670,11 +1684,21 @@ static bool skippy_glm_dsa_direct_sparse_decision_log_enabled() {
 }
 
 static bool skippy_glm_dsa_direct_sparse_attn_enabled() {
-    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_ATTN");
+    if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_ATTN") ||
+        skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_DIRECT_SPARSE_ATTN")) {
+        return false;
+    }
+
+    return true;
 }
 
 static bool skippy_glm_dsa_direct_sparse_prefill_enabled() {
-    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_PREFILL");
+    if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_PREFILL") ||
+        skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_DIRECT_SPARSE_PREFILL")) {
+        return false;
+    }
+
+    return true;
 }
 
 static bool skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled() {
@@ -1700,6 +1724,8 @@ static uint64_t skippy_glm_dsa_dense_sparse_mask_max_bytes() {
     return parsed;
 }
 
+static constexpr int64_t SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K = 128;
+
 static bool skippy_name_starts_with(const char * name, const char * prefix) {
     return name != nullptr && std::strncmp(name, prefix, std::strlen(prefix)) == 0;
 }
@@ -1914,6 +1940,9 @@ static void skippy_glm_dsa_log_direct_sparse_decision_for_tensor(
             sparse_batch > static_cast<int64_t>(prefill_cap) &&
             dense_mask_bytes > dense_mask_limit;
     const bool token_shape_allowed = decode_shape || prefill_shape || large_prefill_shape;
+    const bool direct_top_k_too_large =
+            decode_shape &&
+            sparse_top_k > SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K;
     const char * phase =
             decode_shape ? "decode" :
             (prefill_shape || large_prefill_shape) ? "prefill" :
@@ -1924,6 +1953,7 @@ static void skippy_glm_dsa_log_direct_sparse_decision_for_tensor(
             use_direct && large_prefill_shape ? "dense_mask_guard_large_prefill" :
             !direct_enabled ? "direct_sparse_disabled" :
             !token_shape_allowed ? "token_shape_not_allowed" :
+            direct_top_k_too_large ? "direct_sparse_top_k_too_large" :
             !use_direct ? "dense_mask_fallback" :
             "unknown";
 
-- 
2.53.0

