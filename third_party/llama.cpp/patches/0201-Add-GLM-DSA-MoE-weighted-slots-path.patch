From 14234c4b754fec704350d770df276b276220cf93 Mon Sep 17 00:00:00 2001
From: Mesh LLM <mesh-llm@example.invalid>
Date: Fri, 3 Jul 2026 05:23:15 +1000
Subject: [PATCH] Add GLM DSA MoE weighted slots path

---
 ggml/src/ggml-cpu/ops.cpp              |  3 +-
 ggml/src/ggml-metal/ggml-metal-impl.h  |  2 +-
 ggml/src/ggml-metal/ggml-metal-ops.cpp | 25 +++++++++++--
 ggml/src/ggml-metal/ggml-metal.metal   |  4 +--
 src/llama-graph.cpp                    | 50 ++++++++++++++++++++++++++
 5 files changed, 78 insertions(+), 6 deletions(-)

diff --git a/ggml/src/ggml-cpu/ops.cpp b/ggml/src/ggml-cpu/ops.cpp
index fff5a2ceb..720fdb591 100644
--- a/ggml/src/ggml-cpu/ops.cpp
+++ b/ggml/src/ggml-cpu/ops.cpp
@@ -11174,6 +11174,7 @@ void ggml_compute_forward_moe_weighted_sum(
     const int64_t n_embd        = experts->ne[0];
     const int64_t n_expert_used = experts->ne[1];
     const int64_t n_tokens      = experts->ne[2];
+    const bool already_weighted = ggml_get_op_params_i32(dst, 0) != 0;
 
     const int ith = params->ith;
     const int nth = params->nth;
@@ -11191,7 +11192,7 @@ void ggml_compute_forward_moe_weighted_sum(
         for (int64_t expert = 0; expert < n_expert_used; ++expert) {
             const float value = *(const float *) ((const char *) experts->data +
                     i_embd * experts->nb[0] + expert * experts->nb[1] + token * experts->nb[2]);
-            const float weight = *(const float *) ((const char *) weights->data +
+            const float weight = already_weighted ? 1.0f : *(const float *) ((const char *) weights->data +
                     expert * weights->nb[1] + token * weights->nb[2]);
             acc += value * weight;
         }
diff --git a/ggml/src/ggml-metal/ggml-metal-impl.h b/ggml/src/ggml-metal/ggml-metal-impl.h
index 8d0575315..d498dd2c0 100644
--- a/ggml/src/ggml-metal/ggml-metal-impl.h
+++ b/ggml/src/ggml-metal/ggml-metal-impl.h
@@ -1262,7 +1262,7 @@ typedef struct {
     int32_t  n_embd;
     int32_t  n_tokens;
     int32_t  n_expert_used;
-    int32_t  _pad0;
+    int32_t  already_weighted;
     uint64_t experts_nb0;
     uint64_t experts_nb1;
     uint64_t experts_nb2;
diff --git a/ggml/src/ggml-metal/ggml-metal-ops.cpp b/ggml/src/ggml-metal/ggml-metal-ops.cpp
index a5414544a..16806cf05 100644
--- a/ggml/src/ggml-metal/ggml-metal-ops.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-ops.cpp
@@ -2962,6 +2962,7 @@ int ggml_metal_op_mul_mat_id(ggml_metal_op_t ctx, int idx) {
         }
 
         if (ggml_metal_glm_dsa_dispatch_log_enabled()) {
+            const bool weighted_slots = ggml_get_op_params_i32(op, 0) != 0;
             GGML_LOG_INFO(
                 "skippy: glm_dsa_metal_dispatch op=mul_mat_id kernel=mul_mv_id tensor=%s src0_type=%s src1_type=%s ids_type=%s dst_type=%s ne00=%d ne01=%d experts=%d used_experts=%d tokens=%d min_tokens=%d nr0=%d nr1=%d nsg=%d grid_x=%d grid_y=%d grid_z=%d threads_x=%d threads_y=%d\n",
                 ggml_metal_tensor_name(op),
@@ -2983,6 +2984,26 @@ int ggml_metal_op_mul_mat_id(ggml_metal_op_t ctx, int idx) {
                 grid_z,
                 32,
                 nsg);
+            if (weighted_slots) {
+                GGML_LOG_INFO(
+                    "skippy: glm_dsa_metal_dispatch op=mul_mv_id_weighted_slots kernel=%s tensor=%s src0_type=%s src1_type=%s ids_type=%s dst_type=%s ne00=%d ne01=%d experts=%d used_experts=%d tokens=%d grid_x=%d grid_y=%d grid_z=%d threads_x=%d threads_y=%d\n",
+                    ggml_type_name(op->src[0]->type),
+                    ggml_metal_tensor_name(op),
+                    ggml_type_name(op->src[0]->type),
+                    ggml_type_name(op->src[1]->type),
+                    ggml_type_name(op->src[2]->type),
+                    ggml_type_name(op->type),
+                    ne00,
+                    ne01,
+                    ne02,
+                    ne20,
+                    ne21,
+                    grid_x,
+                    grid_y,
+                    grid_z,
+                    32,
+                    nsg);
+            }
         }
     }
 
@@ -5328,7 +5349,7 @@ int ggml_metal_op_moe_weighted_sum(ggml_metal_op_t ctx, int idx) {
         /*.n_embd        =*/ ne00,
         /*.n_tokens      =*/ ne02,
         /*.n_expert_used =*/ ne01,
-        /*._pad0         =*/ 0,
+        /*.already_weighted =*/ ggml_get_op_params_i32(op, 0) != 0 ? 1 : 0,
         /*.experts_nb0   =*/ nb00,
         /*.experts_nb1   =*/ nb01,
         /*.experts_nb2   =*/ nb02,
@@ -5363,7 +5384,7 @@ int ggml_metal_op_moe_weighted_sum(ggml_metal_op_t ctx, int idx) {
     if (ggml_metal_glm_dsa_dispatch_log_enabled()) {
         GGML_LOG_INFO(
             "skippy: glm_dsa_metal_dispatch op=moe_weighted_sum kernel=%s tensor=%s experts=%s weights=%s embd=%lld tokens=%lld used_experts=%lld grid_x=%d grid_y=%d grid_z=1 threads_x=%d\n",
-            use_x4 ? "f32x4" : "f32",
+            args.already_weighted ? "already_weighted" : (use_x4 ? "f32x4" : "f32"),
             ggml_metal_tensor_name(op),
             ggml_metal_tensor_name(op->src[0]),
             ggml_metal_tensor_name(op->src[1]),
diff --git a/ggml/src/ggml-metal/ggml-metal.metal b/ggml/src/ggml-metal/ggml-metal.metal
index eaad613bd..b20ff854e 100644
--- a/ggml/src/ggml-metal/ggml-metal.metal
+++ b/ggml/src/ggml-metal/ggml-metal.metal
@@ -5937,7 +5937,7 @@ kernel void kernel_moe_weighted_sum_f32(
     for (int32_t expert = 0; expert < args.n_expert_used; ++expert) {
         const float value = ((device const float *) (experts +
                 i_embd*args.experts_nb0 + expert*args.experts_nb1 + token*args.experts_nb2))[0];
-        const float weight = ((device const float *) (weights +
+        const float weight = args.already_weighted ? 1.0f : ((device const float *) (weights +
                 expert*args.weights_nb1 + token*args.weights_nb2))[0];
         acc += value*weight;
     }
@@ -5965,7 +5965,7 @@ kernel void kernel_moe_weighted_sum_f32x4(
     for (int32_t expert = 0; expert < args.n_expert_used; ++expert) {
         const float4 value = ((device const float4 *) (experts +
                 i_embd*args.experts_nb0 + expert*args.experts_nb1 + token*args.experts_nb2))[0];
-        const float weight = ((device const float *) (weights +
+        const float weight = args.already_weighted ? 1.0f : ((device const float *) (weights +
                 expert*args.weights_nb1 + token*args.weights_nb2))[0];
         acc += value*weight;
     }
diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 70ca4f017..738ca1e55 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -110,6 +110,10 @@ static bool skippy_glm_dsa_moe_weighted_sum_enabled() {
     return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_MOE_WEIGHTED_SUM");
 }
 
+static bool skippy_glm_dsa_q3_down_weighted_parallel_enabled() {
+    return skippy_env_enabled("SKIPPY_GLM_DSA_EXPERIMENTAL_Q3_DOWN_WEIGHTED_PARALLEL");
+}
+
 static bool skippy_glm_dsa_moe_route_weights_enabled() {
     if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_MOE_ROUTE_WEIGHTS") ||
         skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_MOE_ROUTE_WEIGHTS")) {
@@ -2467,7 +2471,50 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
             GGML_ABORT("fatal error");
     }
 
+    const bool use_q3_down_weighted_slots =
+        arch == LLM_ARCH_GLM_DSA &&
+        skippy_glm_dsa_q3_down_weighted_parallel_enabled() &&
+        !weight_before_ffn &&
+        down_exps->type == GGML_TYPE_Q3_K &&
+        down_exps_b == nullptr &&
+        down_exps_s == nullptr &&
+        weights->type == GGML_TYPE_F32 &&
+        weights->ne[0] == 1 &&
+        weights->ne[1] == n_expert_used &&
+        weights->ne[2] == n_tokens &&
+        cur->type == GGML_TYPE_F32 &&
+        cur->ne[1] == n_expert_used &&
+        cur->ne[2] == n_tokens;
+
+    if (arch == LLM_ARCH_GLM_DSA && skippy_glm_dsa_q3_down_weighted_parallel_enabled()) {
+        fprintf(stderr,
+            "skippy: glm_dsa_moe_down_weighted_slots_decision layer=%d use=%d down_type=%s has_down_bias=%d has_down_scale=%d weights_type=%s weights_shape=[%lld,%lld,%lld] cur_type=%s cur_shape=[%lld,%lld,%lld] n_expert_used=%lld n_tokens=%lld\n",
+            il,
+            use_q3_down_weighted_slots ? 1 : 0,
+            ggml_type_name(down_exps->type),
+            down_exps_b != nullptr ? 1 : 0,
+            down_exps_s != nullptr ? 1 : 0,
+            ggml_type_name(weights->type),
+            (long long) weights->ne[0],
+            (long long) weights->ne[1],
+            (long long) weights->ne[2],
+            ggml_type_name(cur->type),
+            (long long) cur->ne[0],
+            (long long) cur->ne[1],
+            (long long) cur->ne[2],
+            (long long) n_expert_used,
+            (long long) n_tokens);
+    }
+
+    if (use_q3_down_weighted_slots) {
+        cur = ggml_mul(ctx0, cur, weights);
+        cb(cur, "ffn_moe_down_weighted_input", il);
+    }
+
     experts = build_lora_mm_id(down_exps, cur, selected_experts); // [n_embd, n_expert_used, n_tokens]
+    if (use_q3_down_weighted_slots && experts->op == GGML_OP_MUL_MAT_ID) {
+        experts->op_params[0] = 1;
+    }
     cb(experts, "ffn_moe_down", il);
 
     if (down_exps_b) {
@@ -2500,6 +2547,9 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
 
     if (use_moe_weighted_sum) {
         ggml_tensor * moe_out = ggml_moe_weighted_sum(ctx0, experts, weights);
+        if (use_q3_down_weighted_slots) {
+            moe_out->op_params[0] = 1;
+        }
         ggml_build_forward_expand(gf, moe_out);
         cb(moe_out, "ffn_moe_out", il);
         return moe_out;
-- 
2.54.0 (Apple Git-157)

