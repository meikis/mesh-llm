From eeb5f9d455bbc629ce1f9f8bf1bb6527a0b2771d Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Fri, 3 Jul 2026 09:27:08 +1000
Subject: [PATCH] Default GLM compact flash to four workgroups

---
 ggml/src/ggml-metal/ggml-metal-ops.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/ggml/src/ggml-metal/ggml-metal-ops.cpp b/ggml/src/ggml-metal/ggml-metal-ops.cpp
index 4b9a6fb41..c54d4267b 100644
--- a/ggml/src/ggml-metal/ggml-metal-ops.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-ops.cpp
@@ -3069,7 +3069,7 @@ bool ggml_metal_op_flash_attn_ext_use_vec(const ggml_tensor * op) {
 static int32_t ggml_metal_glm_dsa_compact_flash_nwg_requested() {
     const char * value = getenv("LLAMA_GLM_DSA_COMPACT_FLASH_NWG");
     if (value == nullptr || value[0] == '\0') {
-        return 8;
+        return 4;
     }
 
     const int requested = atoi(value);
@@ -3082,7 +3082,7 @@ static int32_t ggml_metal_glm_dsa_compact_flash_nwg_requested() {
         case 32:
             return requested;
         default:
-            return 8;
+            return 4;
     }
 }
 
-- 
