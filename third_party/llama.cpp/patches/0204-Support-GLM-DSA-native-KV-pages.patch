From 237424bbb7e95261005b5109f7ac22e6d7f6e0f0 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Fri, 3 Jul 2026 09:52:33 +1000
Subject: [PATCH] Support GLM DSA native KV pages

---
 src/skippy.cpp | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 7e24b154d..0d75bf2ea 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -9,6 +9,7 @@
 #include "llama-ext.h"
 #include "llama-graph.h"
 #include "llama-kv-cache.h"
+#include "llama-kv-cache-dsa.h"
 #include "llama-memory-hybrid.h"
 #include "llama-memory-hybrid-iswa.h"
 #include "llama-memory-recurrent.h"
@@ -5690,6 +5691,13 @@ static llama_kv_cache * skippy_get_kv_cache(
     if (auto * kv = dynamic_cast<llama_kv_cache *>(memory)) {
         return kv;
     }
+    if (auto * dsa = dynamic_cast<llama_kv_cache_dsa *>(memory)) {
+        llama_kv_cache * kv = dsa->get_mla();
+        if (kv == nullptr) {
+            skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "runtime has no GLM-DSA MLA KV cache");
+        }
+        return kv;
+    }
 
     skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "runtime memory type is not supported for native KV pages");
     return nullptr;
-- 
