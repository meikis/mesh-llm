From 28cb634d92ddaae2ba18d126b9f71877feab8e84 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Fri, 3 Jul 2026 12:49:27 +1000
Subject: [PATCH] Make GLM DSA direct sparse decode cap tunable

---
 src/llama-graph.cpp | 26 ++++++++++++++++++++++----
 1 file changed, 22 insertions(+), 4 deletions(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 9fb492e9b..abb3682c4 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -187,6 +187,7 @@ struct llama_glm_dsa_sparse_attn_policy {
     bool compact_mask_omitted = false;
     bool compact_candidate = false;
     bool flash_attn = false;
+    int64_t direct_sparse_decode_max_top_k = 0;
 
     bool use_direct_sparse_attn() const {
         return route == llama_glm_dsa_sparse_attn_route::DIRECT_SPARSE;
@@ -197,7 +198,17 @@ struct llama_glm_dsa_sparse_attn_policy {
     }
 };
 
-static constexpr int64_t LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K = 128;
+static constexpr int64_t LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K = 128;
+
+static int64_t skippy_glm_dsa_direct_sparse_decode_max_top_k() {
+    const char * value = getenv("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K");
+    if (value == nullptr || value[0] == '\0') {
+        return LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K;
+    }
+
+    const int64_t parsed = atoll(value);
+    return parsed <= 0 ? INT64_MAX : parsed;
+}
 
 static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
         int64_t sparse_batch,
@@ -227,6 +238,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
     policy.compact_disabled = compact_flash_disabled;
     policy.compact_mask_omitted = compact_mask_omitted;
     policy.flash_attn = flash_attn;
+    policy.direct_sparse_decode_max_top_k = skippy_glm_dsa_direct_sparse_decode_max_top_k();
 
     policy.decode_shape =
             sparse_streams > 0 &&
@@ -251,7 +263,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
 
     policy.compact_large_decode_top_k =
             policy.decode_shape &&
-            sparse_top_k > LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K;
+            sparse_top_k > policy.direct_sparse_decode_max_top_k;
     policy.compact_candidate =
             !compact_flash_disabled &&
             policy.decode_shape &&
@@ -405,6 +417,7 @@ static void skippy_glm_dsa_log_direct_sparse_decision(
         int64_t sparse_kv,
         int64_t sparse_top_k,
         int64_t prefill_cap,
+        int64_t decode_max_top_k,
         int64_t dense_mask_bytes,
         int64_t dense_mask_limit,
         bool    direct_enabled,
@@ -427,12 +440,13 @@ static void skippy_glm_dsa_log_direct_sparse_decision(
     const int64_t kv_topk_ratio = sparse_top_k > 0 ? sparse_kv / sparse_top_k : 0;
 
     LLAMA_LOG_INFO(
-            "skippy: glm_dsa_direct_sparse_decision layer=%d ubatch_tokens=%lld sparse_batch=%lld sparse_streams=%lld prefill_cap=%lld sparse_kv=%lld sparse_top_k=%lld min_kv_topk_ratio=%lld kv_topk_ratio=%lld dense_mask_bytes=%lld dense_mask_limit=%lld phase=%s selector_reason=%s direct_enabled=%d prefill_enabled=%d decode_shape=%d prefill_shape=%d large_prefill_shape=%d token_shape_allowed=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d use_direct=%d\n",
+            "skippy: glm_dsa_direct_sparse_decision layer=%d ubatch_tokens=%lld sparse_batch=%lld sparse_streams=%lld prefill_cap=%lld decode_max_top_k=%lld sparse_kv=%lld sparse_top_k=%lld min_kv_topk_ratio=%lld kv_topk_ratio=%lld dense_mask_bytes=%lld dense_mask_limit=%lld phase=%s selector_reason=%s direct_enabled=%d prefill_enabled=%d decode_shape=%d prefill_shape=%d large_prefill_shape=%d token_shape_allowed=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d use_direct=%d\n",
             layer,
             (long long) ubatch_tokens,
             (long long) sparse_batch,
             (long long) sparse_streams,
             (long long) prefill_cap,
+            (long long) decode_max_top_k,
             (long long) sparse_kv,
             (long long) sparse_top_k,
             0LL,
@@ -459,6 +473,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
         int64_t ubatch_tokens,
         int64_t visible_kv,
         int64_t top_k,
+        int64_t decode_max_top_k,
         bool    disabled,
         bool    large_decode_top_k,
         bool    enabled,
@@ -476,11 +491,12 @@ static void skippy_glm_dsa_log_compact_flash_policy(
     }
 
     LLAMA_LOG_INFO(
-            "skippy: glm_dsa_compact_flash_policy layer=%d ubatch_tokens=%lld visible_kv=%lld top_k=%lld kv_topk_ratio=%lld min_kv_topk_ratio=%lld forced=%d disabled=%d large_decode_top_k=%d ratio_ok=%d enabled=%d flash_attn=%d phase=%s decode_shape=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d no_mask=%d use_compact=%d selector_reason=%s\n",
+            "skippy: glm_dsa_compact_flash_policy layer=%d ubatch_tokens=%lld visible_kv=%lld top_k=%lld decode_max_top_k=%lld kv_topk_ratio=%lld min_kv_topk_ratio=%lld forced=%d disabled=%d large_decode_top_k=%d ratio_ok=%d enabled=%d flash_attn=%d phase=%s decode_shape=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d no_mask=%d use_compact=%d selector_reason=%s\n",
             layer,
             (long long) ubatch_tokens,
             (long long) visible_kv,
             (long long) top_k,
+            (long long) decode_max_top_k,
             top_k > 0 ? (long long) (visible_kv/top_k) : 0LL,
             2LL,
             0,
@@ -3537,6 +3553,7 @@ ggml_tensor * llm_graph_context::build_attn(
             n_sparse_kv,
             n_sparse_top_k,
             direct_sparse_prefill_max_tokens,
+            sparse_policy.direct_sparse_decode_max_top_k,
             dense_sparse_mask_bytes,
             dense_sparse_mask_limit,
             sparse_policy.direct_enabled,
@@ -3558,6 +3575,7 @@ ggml_tensor * llm_graph_context::build_attn(
             ubatch.n_tokens,
             n_sparse_kv,
             n_sparse_top_k,
+            sparse_policy.direct_sparse_decode_max_top_k,
             sparse_policy.compact_disabled,
             sparse_policy.compact_large_decode_top_k,
             sparse_policy.compact_candidate,
-- 
2.53.0

