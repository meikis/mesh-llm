+static void decode_tokens(llama_context * lctx, const std::vector<llama_token> & tokens, llama_pos start_pos) {
+    llama_batch batch = llama_batch_init(tokens.size(), 0, 1);
+    for (size_t i = 0; i < tokens.size(); ++i) {
+        common_batch_add(batch, tokens[i], start_pos + (llama_pos) i, {0}, true);
+    }
+    batch.n_tokens = tokens.size();
+    if (llama_decode(lctx, batch)) {
+        llama_batch_free(batch);
+        throw std::runtime_error("failed to decode batch");
+    }
+    llama_batch_free(batch);
+}
+
+static bool test_glm_dsa_compact_decode_graph(
+        const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
+    try {
+        gguf_context_ptr gguf_ctx = get_gguf_ctx(
+                LLM_ARCH_GLM_DSA,
+                true,
+                glm_dsa_indexshare_fixture::FULL_SHARED);
+        glm_dsa_graph_op_counts counts;
+        scoped_test_env compact_decode_cap("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K", "4");
+        scoped_test_env graph_reuse_disabled("LLAMA_GRAPH_REUSE_DISABLE", "1");
+        auto model_ctx = get_model_and_ctx(
+                gguf_ctx.get(),
+                nullptr,
+                seed,
+                devs,
+                LLAMA_SPLIT_MODE_LAYER,
+                false,
+                glm_dsa_graph_op_counter_callback,
+                &counts,
+                LLAMA_FLASH_ATTN_TYPE_ENABLED);
+
+        const uint32_t n_vocab = llama_vocab_n_tokens(llama_model_get_vocab(model_ctx.first.get()));
+        const std::vector<llama_token> tokens = get_tokens(17, n_vocab, seed);
+        decode_tokens(model_ctx.second.get(), std::vector<llama_token>(tokens.begin(), tokens.begin() + 16), 0);
+
+        counts = {};
+        decode_tokens(model_ctx.second.get(), std::vector<llama_token>{tokens[16]}, 16);
+
+        if (counts.compact_get_rows == 0 || counts.flash_attn == 0 || counts.sparse_mask != 0) {
+            fprintf(stderr,
+                    "GLM_DSA compact decode graph counted total=%d compact_get_rows=%d flash_attn=%d sparse_mask=%d\n",
+                    counts.total, counts.compact_get_rows, counts.flash_attn, counts.sparse_mask);
+            return false;
+        }
+        return true;
+    } catch (const std::exception & err) {
+        fprintf(stderr, "GLM_DSA compact decode graph test failed: %s\n", err.what());
+        return false;
+    }
+}
