 tests/test-backend-ops.cpp | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/tests/test-backend-ops.cpp b/tests/test-backend-ops.cpp
index 12bca783b..ec484a46b 100644
--- a/tests/test-backend-ops.cpp
+++ b/tests/test-backend-ops.cpp
@@ -7602,6 +7602,11 @@ struct test_glm_dsa_selected_row_flash : public test_case {
         return 5e-3;
     }
 
+    uint64_t op_flops(ggml_tensor * t) override {
+        GGML_UNUSED(t);
+        return 2ULL * (uint64_t) top_k * (576 + 512);
+    }
+
     bool run_whole_graph() override {
         return true;
     }
@@ -10422,6 +10427,10 @@ static std::vector<std::unique_ptr<test_case>> make_test_cases_perf() {
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q2_K, GGML_TYPE_F32, 256, 8, false, 2048, 1, 6144));
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q3_K, GGML_TYPE_F32, 256, 8, false, 6144, 1, 2048));
 
+    // GLM-DSA sparse-attention decode shapes.
+    test_cases.emplace_back(new test_glm_dsa_selected_row_flash(257, 64));
+    test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, 257, 1, 1, 1, 64, 1));
+    test_cases.emplace_back(new test_flash_attn_ext(576, 512, 1, {1, 1}, 257, 1, true, false, 0, 0, GGML_PREC_F32, GGML_TYPE_F16, GGML_TYPE_F16));
 
     // gpt-oss-20b
     for (int bs : {1, 4, 8, 512}) {
