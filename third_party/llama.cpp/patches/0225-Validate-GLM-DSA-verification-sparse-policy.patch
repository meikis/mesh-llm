         int64_t dense_mask_limit,
@@ -305,20 +325,28 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
             sparse_streams > 0 &&
             sparse_batch == 1 &&
             ubatch_tokens == sparse_streams;
+    policy.verify_shape =
+            verification_batch &&
+            direct_sparse_prefill_enabled &&
+            sparse_batch <= prefill_cap;
     policy.prefill_shape =
+            !verification_batch &&
             direct_sparse_prefill_enabled &&
             sparse_batch <= prefill_cap;
     policy.large_prefill_shape =
+            !verification_batch &&
             direct_sparse_prefill_enabled &&
             unproven_large_direct_sparse_prefill_enabled &&
             sparse_batch > prefill_cap &&
             dense_mask_bytes > dense_mask_limit;
     policy.token_shape_allowed =
             policy.decode_shape ||
+            policy.verify_shape ||
             policy.prefill_shape ||
             policy.large_prefill_shape;
     policy.phase =
             policy.decode_shape ? "decode" :
+            policy.verify_shape ? "verify" :
             (policy.prefill_shape || policy.large_prefill_shape) ? "prefill" :
             "other";
 
@@ -360,6 +388,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
