+    int64_t max_compact_rows = 0;
 };
 
 static bool glm_dsa_is_indexshare_top_k_tensor(const ggml_tensor * tensor) {
@@ -460,6 +464,7 @@ static bool glm_dsa_graph_op_counter_callback(ggml_tensor * tensor, bool ask, vo
     } else if (tensor->op == GGML_OP_TOP_K) {
         if (strncmp(tensor->name, "ffn_moe_topk", strlen("ffn_moe_topk")) != 0) {
             ++counts->top_k;
+            counts->max_top_k_width = std::max(counts->max_top_k_width, tensor->ne[0]);
         }
     } else if (tensor->op == GGML_OP_FLASH_ATTN_EXT) {
         ++counts->flash_attn;
@@ -474,6 +479,7 @@ static bool glm_dsa_graph_op_counter_callback(ggml_tensor * tensor, bool ask, vo
     }
     if (strncmp(tensor->name, "dsa_compact_", strlen("dsa_compact_")) == 0) {
         ++counts->compact_get_rows;
+        counts->max_compact_rows = std::max(counts->max_compact_rows, tensor->ne[1]);
     }
     if (strncmp(tensor->name, "dsa_sparse_mask", strlen("dsa_sparse_mask")) == 0) {
         ++counts->sparse_mask_nodes;
@@ -611,11 +617,17 @@ static void decode_tokens(llama_context * lctx, const std::vector<llama_token> &
 }
 
 static glm_dsa_graph_op_counts run_glm_dsa_decode_graph_after_prefill(
-        const size_t seed, const std::vector<ggml_backend_dev_t> & devs, uint32_t n_prefill = 16) {
+        const size_t seed,
+        const std::vector<ggml_backend_dev_t> & devs,
+        uint32_t n_prefill = 16,
+        uint32_t context_length = 128,
+        uint32_t indexer_top_k = 8) {
     gguf_context_ptr gguf_ctx = get_gguf_ctx(
             LLM_ARCH_GLM_DSA,
             true,
-            glm_dsa_indexshare_fixture::FULL_SHARED);
+            glm_dsa_indexshare_fixture::FULL_SHARED,
+            context_length,
+            indexer_top_k);
     glm_dsa_graph_op_counts counts;
     auto model_ctx = get_model_and_ctx(
             gguf_ctx.get(),
@@ -794,6 +806,30 @@ static bool test_glm_dsa_short_history_compact_decode_graph(
     }
 }
 
+static bool test_glm_dsa_native_top_k_compact_decode_graph(
+        const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
+    try {
+        scoped_test_env graph_reuse_disabled("LLAMA_GRAPH_REUSE_DISABLE", "1");
+        // GLM-5.2 uses top_k=768. After a 768-token prefix, the next token sees
+        // 769 visible KV entries while IndexShare produces 768 selected rows.
+        // This is the model-native compact selected-KV decode shape.
+        const glm_dsa_graph_op_counts counts = run_glm_dsa_decode_graph_after_prefill(seed, devs, 768, 1024, 768);
+
+        if (counts.top_k == 0 || counts.max_top_k_width != 768 || counts.compact_get_rows == 0 || counts.max_compact_rows != 768 ||
+                counts.flash_attn == 0 || counts.sparse_mask != 0 || counts.sparse_mask_nodes != 0 || counts.dsa_sparse_attn != 0) {
+            fprintf(stderr,
+                    "GLM_DSA native top-k compact decode graph counted total=%d top_k=%d max_top_k_width=%lld compact_get_rows=%d max_compact_rows=%lld flash_attn=%d sparse_mask=%d sparse_mask_nodes=%d dsa_sparse_attn=%d\n",
+                    counts.total, counts.top_k, (long long) counts.max_top_k_width, counts.compact_get_rows, (long long) counts.max_compact_rows,
+                    counts.flash_attn, counts.sparse_mask, counts.sparse_mask_nodes, counts.dsa_sparse_attn);
+            return false;
+        }
+        return true;
+    } catch (const std::exception & err) {
+        fprintf(stderr, "GLM_DSA native top-k compact decode graph test failed: %s\n", err.what());
+        return false;
+    }
+}
+
 static bool test_glm_dsa_compact_disabled_decode_graph(
         const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
     try {
@@ -1154,6 +1190,7 @@ static int test_backends(const llm_arch target_arch, const size_t seed, const gg
                 test_glm_dsa_compact_min_kv_decode_graph(seed, {}) &&
                 test_glm_dsa_default_compact_decode_graph(seed, {}) &&
                 test_glm_dsa_short_history_compact_decode_graph(seed, {}) &&
+                test_glm_dsa_native_top_k_compact_decode_graph(seed, {}) &&
                 test_glm_dsa_compact_disabled_decode_graph(seed, {}) &&
                 test_glm_dsa_verify_dense_graph(seed, {}) &&
                 test_glm_dsa_short_prefill_dense_graph(seed, {}) &&
