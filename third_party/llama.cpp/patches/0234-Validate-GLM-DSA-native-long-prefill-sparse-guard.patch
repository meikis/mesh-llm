         llama_model * model, llama_context * lctx, const std::vector<llama_token> & tokens, bool encode = false) {
     const uint32_t n_vocab  = llama_vocab_n_tokens(llama_model_get_vocab(model));
@@ -1194,7 +1264,8 @@ static int test_backends(const llm_arch target_arch, const size_t seed, const gg
                 test_glm_dsa_compact_disabled_decode_graph(seed, {}) &&
                 test_glm_dsa_verify_dense_graph(seed, {}) &&
                 test_glm_dsa_short_prefill_dense_graph(seed, {}) &&
-                test_glm_dsa_long_prefill_dense_mask_guard_graph(seed, {});
+                test_glm_dsa_long_prefill_dense_mask_guard_graph(seed, {}) &&
+                test_glm_dsa_native_top_k_long_prefill_dense_mask_guard_graph(seed, {});
         if (!glm_dsa_contract_ok) {
             fprintf(stderr, "GLM_DSA IndexShare metadata contract test failed\n");
             all_ok = false;
