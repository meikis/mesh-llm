From 4d5cf1c5020da14894ba63ef20b8e9c680651015 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 13:20:28 +1000
Subject: [PATCH] Measure GLM DSA fused shared expert path

---
 scripts/glm52-phase-e-moe-report.sh | 36 ++++++++++++++--------
 tests/test-backend-ops.cpp          | 46 ++++++++++++++++++++++-------
 2 files changed, 59 insertions(+), 23 deletions(-)

diff --git a/scripts/glm52-phase-e-moe-report.sh b/scripts/glm52-phase-e-moe-report.sh
index 97ab228cc..e954942aa 100755
--- a/scripts/glm52-phase-e-moe-report.sh
+++ b/scripts/glm52-phase-e-moe-report.sh
@@ -110,13 +110,16 @@ weighted_1 = find("MOE_WEIGHTED_SUM", "n_tokens=1")
 weighted_4 = find("MOE_WEIGHTED_SUM", "n_tokens=4")
 consumer_q = find("TOPK_MOE_GLM_CONSUMER", "gate_type=q2_K")
 consumer_q_weighted = find("TOPK_MOE_GLM_CONSUMER", "weighted_down=1")
-shexp_q = find("GLM_SHEXP_CONSUMER", "n_embd=6144")
-shexp_small = find("GLM_SHEXP_CONSUMER", "n_embd=256")
+shexp_unfused = find("GLM_SHEXP_CONSUMER", "n_embd=6144", "fused_glu=0")
+shexp_fused = find("GLM_SHEXP_CONSUMER", "n_embd=6144", "fused_glu=1")
+shexp_small = find("GLM_SHEXP_CONSUMER", "n_embd=256", "fused_glu=0")
+shexp_small_fused = find("GLM_SHEXP_CONSUMER", "n_embd=256", "fused_glu=1")
 shexp_gate = find("GLM_SHEXP_COMPONENT", "component=0", "n_embd=6144")
 shexp_up = find("GLM_SHEXP_COMPONENT", "component=1", "n_embd=6144")
 shexp_gate_up = find("GLM_SHEXP_COMPONENT", "component=2", "n_embd=6144")
 shexp_down = find("GLM_SHEXP_COMPONENT", "component=3", "n_embd=6144")
 shexp_add = find("GLM_SHEXP_COMPONENT", "component=4", "n_embd=6144")
+shexp_swiglu = find("GLM_SHEXP_COMPONENT", "component=5", "n_embd=6144")
 gate_up = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=2048,n=1,k=6144")
 merged_gate_up = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=4096,n=1,k=6144")
 down_q2 = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=6144,n=1,k=2048")
@@ -152,11 +155,14 @@ add_row("Weighted sum, 1 token", weighted_1)
 add_row("Weighted sum, 4 tokens", weighted_4)
 add_row("Small quantized whole-graph consumer", consumer_q)
 add_row("Small quantized whole-graph consumer, weighted down", consumer_q_weighted)
-add_row("Small shared expert + final add", shexp_small)
-add_row("Shared expert + final add", shexp_q)
+add_row("Small shared expert + final add, unfused diagnostic", shexp_small)
+add_row("Small shared expert + final add, fused GLU", shexp_small_fused)
+add_row("Shared expert + final add, unfused diagnostic", shexp_unfused)
+add_row("Shared expert + final add, fused GLU", shexp_fused)
 add_row("Shared gate matmul", shexp_gate)
 add_row("Shared up matmul", shexp_up)
-add_row("Shared activation/mul whole graph", shexp_gate_up)
+add_row("Shared activation/mul whole graph, unfused diagnostic", shexp_gate_up)
+add_row("Shared SwiGLU split", shexp_swiglu)
 add_row("Shared down matmul", shexp_down)
 add_row("Shared final add", shexp_add)
 add_row("Routed gate/up matmul", gate_up)
@@ -183,16 +189,20 @@ if estimated_decode is not None:
         lines.append(f"- q2_K down estimate: `{q2_down_cost:.2f} us` ({estimated_decode / q2_down_cost:.2f}x faster than current estimate, quality tradeoff not measured here).")
     if consumer_q and consumer_q_weighted:
         lines.append(f"- Small weighted-down whole-graph fixture: `{consumer_q_weighted['us']:.2f} us` ({consumer_q['us'] / consumer_q_weighted['us']:.2f}x faster than baseline).")
-    if shexp_q:
-        full_ffn = estimated_decode + shexp_q["us"]
-        lines.append(f"- Shared expert + final add: `{shexp_q['us']:.2f} us`; routed+shared FFN estimate: `{full_ffn:.2f} us`.")
-        lines.append(f"- Shared expert share of routed+shared estimate: `{100.0 * shexp_q['us'] / full_ffn:.1f}%`.")
-    if all(row is not None for row in [shexp_gate, shexp_up, shexp_gate_up, shexp_down, shexp_add]):
-        shexp_components = shexp_gate["us"] + shexp_up["us"] + shexp_gate_up["us"] + shexp_down["us"] + shexp_add["us"]
+    if shexp_fused:
+        full_ffn = estimated_decode + shexp_fused["us"]
+        lines.append(f"- Shared expert + final add, fused GLU: `{shexp_fused['us']:.2f} us`; routed+shared FFN estimate: `{full_ffn:.2f} us`.")
+        lines.append(f"- Shared expert share of routed+shared estimate: `{100.0 * shexp_fused['us'] / full_ffn:.1f}%`.")
+    if shexp_unfused and shexp_fused:
+        lines.append(f"- Unfused diagnostic shared expert: `{shexp_unfused['us']:.2f} us`; fused GLU is `{shexp_unfused['us'] / shexp_fused['us']:.2f}x` faster.")
+    if all(row is not None for row in [shexp_gate, shexp_up, shexp_swiglu, shexp_down, shexp_add]):
+        shexp_components = shexp_gate["us"] + shexp_up["us"] + shexp_swiglu["us"] + shexp_down["us"] + shexp_add["us"]
         shexp_matmuls = shexp_gate["us"] + shexp_up["us"] + shexp_down["us"]
-        lines.append(f"- Shared expert component row sum: `{shexp_components:.2f} us`.")
+        lines.append(f"- Shared expert fused component row sum: `{shexp_components:.2f} us`.")
         lines.append(f"- Shared expert matmuls: `{shexp_matmuls:.2f} us` ({100.0 * shexp_matmuls / shexp_components:.1f}% of component row sum).")
-        lines.append(f"- Shared activation/mul whole-graph row + final add: `{shexp_gate_up['us'] + shexp_add['us']:.2f} us`.")
+        lines.append(f"- Shared SwiGLU split + final add: `{shexp_swiglu['us'] + shexp_add['us']:.2f} us`.")
+    if shexp_gate_up and shexp_swiglu:
+        lines.append(f"- Unfused activation/mul diagnostic: `{shexp_gate_up['us']:.2f} us`; fused SwiGLU split: `{shexp_swiglu['us']:.2f} us` (`{shexp_gate_up['us'] / shexp_swiglu['us']:.2f}x` faster).")
 else:
     lines.append("- Missing rows prevented the per-layer estimate.")
 
diff --git a/tests/test-backend-ops.cpp b/tests/test-backend-ops.cpp
index 35e924f2c..b3d046c3f 100644
--- a/tests/test-backend-ops.cpp
+++ b/tests/test-backend-ops.cpp
@@ -6325,6 +6325,7 @@ struct test_glm_shexp_consumer : public test_case {
     const int64_t n_embd;
     const int64_t n_ff;
     const int64_t n_tokens;
+    const bool fused_glu;
 
     test_glm_shexp_consumer(
             ggml_type gate_type = GGML_TYPE_Q4_K,
@@ -6332,20 +6333,22 @@ struct test_glm_shexp_consumer : public test_case {
             ggml_type down_type = GGML_TYPE_Q4_K,
             int64_t   n_embd    = 6144,
             int64_t   n_ff      = 2048,
-            int64_t   n_tokens  = 1)
+            int64_t   n_tokens  = 1,
+            bool      fused_glu = false)
         : gate_type(gate_type),
           up_type(up_type),
           down_type(down_type),
           n_embd(n_embd),
           n_ff(n_ff),
-          n_tokens(n_tokens) {
+          n_tokens(n_tokens),
+          fused_glu(fused_glu) {
         GGML_ASSERT(n_embd % ggml_blck_size(gate_type) == 0);
         GGML_ASSERT(n_embd % ggml_blck_size(up_type) == 0);
         GGML_ASSERT(n_ff   % ggml_blck_size(down_type) == 0);
     }
 
     std::string vars() override {
-        return VARS_TO_STR6(gate_type, up_type, down_type, n_embd, n_ff, n_tokens);
+        return VARS_TO_STR7(gate_type, up_type, down_type, n_embd, n_ff, n_tokens, fused_glu);
     }
 
     std::string op_desc(ggml_tensor * t) override {
@@ -6378,11 +6381,17 @@ struct test_glm_shexp_consumer : public test_case {
         ggml_tensor * up = ggml_mul_mat(ctx, ups, cur);
         ggml_set_name(up, "ffn_shexp_up");
 
-        ggml_tensor * act = ggml_silu(ctx, gate);
-        ggml_set_name(act, "ffn_shexp_gate_silu");
+        ggml_tensor * act = nullptr;
+        if (fused_glu) {
+            act = ggml_swiglu_split(ctx, gate, up);
+            ggml_set_name(act, "ffn_shexp_swiglu");
+        } else {
+            act = ggml_silu(ctx, gate);
+            ggml_set_name(act, "ffn_shexp_gate_silu");
 
-        act = ggml_mul(ctx, act, up);
-        ggml_set_name(act, "ffn_shexp_gate_up");
+            act = ggml_mul(ctx, act, up);
+            ggml_set_name(act, "ffn_shexp_gate_up");
+        }
 
         ggml_tensor * shexp = ggml_mul_mat(ctx, downs, act);
         ggml_set_name(shexp, "ffn_shexp");
@@ -6434,7 +6443,7 @@ struct test_glm_shexp_component : public test_case {
           n_embd(n_embd),
           n_ff(n_ff),
           n_tokens(n_tokens) {
-        GGML_ASSERT(component >= 0 && component <= 4);
+        GGML_ASSERT(component >= 0 && component <= 5);
         GGML_ASSERT(n_embd % ggml_blck_size(gate_type) == 0);
         GGML_ASSERT(n_embd % ggml_blck_size(up_type) == 0);
         GGML_ASSERT(n_ff   % ggml_blck_size(down_type) == 0);
@@ -6460,6 +6469,7 @@ struct test_glm_shexp_component : public test_case {
             case 2: return build_gate_up(ctx);
             case 3: return build_down_matmul(ctx);
             case 4: return build_output_add(ctx);
+            case 5: return build_swiglu(ctx);
             default: GGML_ABORT("invalid GLM shared expert component");
         }
     }
@@ -6527,6 +6537,18 @@ struct test_glm_shexp_component : public test_case {
         return out;
     }
 
+    ggml_tensor * build_swiglu(ggml_context * ctx) {
+        ggml_tensor * gate = ggml_new_tensor_3d(ctx, GGML_TYPE_F32, n_ff, 1, n_tokens);
+        ggml_set_name(gate, "ffn_shexp_gate");
+
+        ggml_tensor * up = ggml_new_tensor_3d(ctx, GGML_TYPE_F32, n_ff, 1, n_tokens);
+        ggml_set_name(up, "ffn_shexp_up");
+
+        ggml_tensor * act = ggml_swiglu_split(ctx, gate, up);
+        ggml_set_name(act, "ffn_shexp_swiglu");
+        return act;
+    }
+
     double max_nmse_err() override {
         return 5e-4;
     }
@@ -6537,6 +6559,7 @@ struct test_glm_shexp_component : public test_case {
                     strcmp(t->name, "ffn_shexp_gate") == 0 ||
                     strcmp(t->name, "ffn_shexp_up") == 0 ||
                     strcmp(t->name, "ffn_shexp_gate_up") == 0 ||
+                    strcmp(t->name, "ffn_shexp_swiglu") == 0 ||
                     strcmp(t->name, "ffn_shexp") == 0 ||
                     strcmp(t->name, "ffn_moe_out") == 0) {
                 init_tensor_uniform(t, -0.5f, 0.5f);
@@ -10443,7 +10466,8 @@ static std::vector<std::unique_ptr<test_case>> make_test_cases_eval() {
     test_cases.emplace_back(new test_topk_moe_glm_consumer());
     test_cases.emplace_back(new test_topk_moe_glm_consumer(GGML_TYPE_Q2_K, GGML_TYPE_Q2_K, GGML_TYPE_Q3_K, 256, 256));
     test_cases.emplace_back(new test_glm_shexp_consumer(GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256));
-    for (int component = 0; component <= 4; ++component) {
+    test_cases.emplace_back(new test_glm_shexp_consumer(GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256, 1, true));
+    for (int component = 0; component <= 5; ++component) {
         test_cases.emplace_back(new test_glm_shexp_component(component, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256));
     }
 
@@ -10689,8 +10713,10 @@ static std::vector<std::unique_ptr<test_case>> make_test_cases_perf() {
     test_cases.emplace_back(new test_topk_moe_glm_consumer(GGML_TYPE_Q2_K, GGML_TYPE_Q2_K, GGML_TYPE_Q3_K, 256, 256));
     test_cases.emplace_back(new test_topk_moe_glm_consumer(GGML_TYPE_Q2_K, GGML_TYPE_Q2_K, GGML_TYPE_Q3_K, 256, 256, true));
     test_cases.emplace_back(new test_glm_shexp_consumer(GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256));
+    test_cases.emplace_back(new test_glm_shexp_consumer(GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256, 1, true));
     test_cases.emplace_back(new test_glm_shexp_consumer());
-    for (int component = 0; component <= 4; ++component) {
+    test_cases.emplace_back(new test_glm_shexp_consumer(GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 6144, 2048, 1, true));
+    for (int component = 0; component <= 5; ++component) {
         test_cases.emplace_back(new test_glm_shexp_component(component, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, GGML_TYPE_Q4_K, 256, 256));
         test_cases.emplace_back(new test_glm_shexp_component(component));
     }
-- 
