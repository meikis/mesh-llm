From 4f6cae0ba53d52c9a8ab5da25ce6c85284a77272 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sun, 5 Jul 2026 12:45:12 +1000
Subject: [PATCH] Default GLM DSA q3 down fixed-block Metal kernel

---
 ggml/src/ggml-metal/ggml-metal-device.cpp | 11 ++++++++---
 scripts/glm52-phase-e-moe-report.sh       |  3 +++
 2 files changed, 11 insertions(+), 3 deletions(-)

diff --git a/ggml/src/ggml-metal/ggml-metal-device.cpp b/ggml/src/ggml-metal/ggml-metal-device.cpp
index 1983a296d..9ba82c3f0 100644
--- a/ggml/src/ggml-metal/ggml-metal-device.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-device.cpp
@@ -53,9 +53,14 @@ static int ggml_metal_glm_dsa_q3_k_mul_mv_id_nr0_requested() {
     }
 }
 
-static bool ggml_metal_glm_dsa_q3_k_mul_mv_id_glm_down_requested() {
+static bool ggml_metal_glm_dsa_q3_k_mul_mv_id_glm_down_enabled() {
     const char * value = getenv("LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_GLM_DOWN");
-    return value != nullptr && value[0] != '\0' && atoi(value) != 0;
+    if (value != nullptr && value[0] != '\0') {
+        return atoi(value) != 0;
+    }
+
+    const char * disabled = getenv("LLAMA_GLM_DSA_DISABLE_Q3_K_MUL_MV_ID_GLM_DOWN");
+    return disabled == nullptr || disabled[0] == '\0' || atoi(disabled) == 0;
 }
 
 ggml_metal_device_t ggml_metal_device_get(int device) {
@@ -1248,7 +1253,7 @@ ggml_metal_pipeline_with_params ggml_metal_library_get_pipeline_mul_mv_id(ggml_m
                     op->src[2]->ne[1] == 1;
                 if (is_glm_down &&
                         nr0 == N_R0_Q3_K &&
-                        ggml_metal_glm_dsa_q3_k_mul_mv_id_glm_down_requested()) {
+                        ggml_metal_glm_dsa_q3_k_mul_mv_id_glm_down_enabled()) {
                     suffix = "_glm_down";
                 } else if (nr0 != N_R0_Q3_K) {
                     snprintf(name, sizeof(name), "_r%d", nr0);
diff --git a/scripts/glm52-phase-e-moe-report.sh b/scripts/glm52-phase-e-moe-report.sh
index 795565ab8..09d841e8c 100755
--- a/scripts/glm52-phase-e-moe-report.sh
+++ b/scripts/glm52-phase-e-moe-report.sh
@@ -411,6 +411,7 @@ if [[ "${GLM52_PHASE_E_KERNEL_SWEEP:-0}" != "0" ]]; then
         --output console > "${forced_mm_log}" 2>&1
 
     for nsg in 1 2 4; do
+        LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_GLM_DOWN=0 \
         LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_NSG="${nsg}" \
             "${test_backend_ops}" perf \
             -o MUL_MAT_ID \
@@ -419,6 +420,7 @@ if [[ "${GLM52_PHASE_E_KERNEL_SWEEP:-0}" != "0" ]]; then
     done
 
     for nr0 in 1 2 4 8; do
+        LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_GLM_DOWN=0 \
         LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_NR0="${nr0}" \
             "${test_backend_ops}" perf \
             -o MUL_MAT_ID \
@@ -484,6 +486,7 @@ lines = [
     "## Optional Kernel Sweep",
     "",
     "This sweep is enabled by `GLM52_PHASE_E_KERNEL_SWEEP=1` and records kernel-policy evidence for tempting GLM-DSA MoE alternatives.",
+    "The ordinary q3_K baseline rows explicitly set `LLAMA_GLM_DSA_Q3_K_MUL_MV_ID_GLM_DOWN=0` so the fixed-block default is not compared to itself.",
     "",
     "| Case | Shape | Time |",
     "| --- | --- | ---: |",
-- 
2.53.0

