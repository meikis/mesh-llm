From c2c68b211a40fb21a7f5c08e5788f2a26433fd4c Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sun, 5 Jul 2026 13:03:25 +1000
Subject: [PATCH] Gate GLM DSA compact decode kernel choice

---
 scripts/glm52-phase-d-policy-report.sh | 44 ++++++++++++++++++++++++--
 tests/test-backend-ops.cpp             |  6 +++-
 2 files changed, 47 insertions(+), 3 deletions(-)

diff --git a/scripts/glm52-phase-d-policy-report.sh b/scripts/glm52-phase-d-policy-report.sh
index 3a57f7d91..0c973f558 100755
--- a/scripts/glm52-phase-d-policy-report.sh
+++ b/scripts/glm52-phase-d-policy-report.sh
@@ -50,6 +50,8 @@ mkdir -p "${out_dir}"
 phase_log="${out_dir}/phase-gates.log"
 perf_sparse_log="${out_dir}/sparse-policy-perf.console.log"
 perf_sparse_csv="${out_dir}/sparse-policy-perf.csv"
+perf_compact_fallback_log="${out_dir}/compact-gather-flash-fallback.console.log"
+perf_compact_fallback_csv="${out_dir}/compact-gather-flash-fallback.csv"
 perf_dense_log="${out_dir}/dense-flash-perf.console.log"
 perf_dense_csv="${out_dir}/dense-flash-perf.csv"
 summary="${out_dir}/summary.md"
@@ -68,6 +70,19 @@ sparse_filter='kv=1024|n_kv=1024|n_kv=257,n_batch=4|n_kv=257,n_batch=8|n_kv=257,
     -p "${sparse_filter}" \
     --output csv > "${perf_sparse_csv}"
 
+echo "== GLM-DSA compact gather + flash fallback row =="
+compact_fallback_filter='kv=1024,top_k=768'
+SKIPPY_GLM_DSA_DISABLE_SELECTED_ROW_FLASH=1 \
+"${test_backend_ops}" perf \
+    -o GLM_DSA_SELECTED_ROW_FLASH \
+    -p "${compact_fallback_filter}" \
+    --output console 2>&1 | tee "${perf_compact_fallback_log}"
+SKIPPY_GLM_DSA_DISABLE_SELECTED_ROW_FLASH=1 \
+"${test_backend_ops}" perf \
+    -o GLM_DSA_SELECTED_ROW_FLASH \
+    -p "${compact_fallback_filter}" \
+    --output csv > "${perf_compact_fallback_csv}"
+
 echo "== GLM-DSA dense flash comparison rows =="
 dense_filter='kv=257,nb=4|kv=257,nb=8|kv=257,nb=16'
 "${test_backend_ops}" perf \
@@ -79,12 +94,12 @@ dense_filter='kv=257,nb=4|kv=257,nb=8|kv=257,nb=16'
     -p "${dense_filter}" \
     --output csv > "${perf_dense_csv}"
 
-python3 - "${phase_log}" "${perf_sparse_log}" "${perf_dense_log}" "${summary}" <<'PY'
+python3 - "${phase_log}" "${perf_sparse_log}" "${perf_compact_fallback_log}" "${perf_dense_log}" "${summary}" <<'PY'
 import re
 import sys
 from pathlib import Path
 
-phase_log, sparse_log, dense_log, summary = map(Path, sys.argv[1:])
+phase_log, sparse_log, compact_fallback_log, dense_log, summary = map(Path, sys.argv[1:])
 
 line_start_re = re.compile(r"^\s+[A-Z0-9_]+\([^)]*\):")
 line_re = re.compile(
@@ -122,6 +137,7 @@ def parse(path):
     return rows
 
 rows = parse(sparse_log) + parse(dense_log)
+fallback_rows = parse(compact_fallback_log)
 
 def find(name, needle):
     for row in rows:
@@ -131,6 +147,10 @@ def find(name, needle):
 
 selected_1024 = find("GLM_DSA_SELECTED_ROW_FLASH", "kv=1024,top_k=768")
 sparse_1024 = find("DSA_SPARSE_ATTN", "n_kv=1024")
+compact_fallback_1024 = next((
+    row for row in fallback_rows
+    if row["name"] == "GLM_DSA_SELECTED_ROW_FLASH" and "kv=1024,top_k=768" in row["params"]
+), None)
 
 short_pairs = []
 for batch in (4, 8, 16):
@@ -148,6 +168,7 @@ lines = [
     "",
     f"- Phase gates: `{phase_log.name}`",
     f"- Sparse policy perf: `{sparse_log.name}`",
+    f"- Compact gather fallback perf: `{compact_fallback_log.name}`",
     f"- Dense flash perf: `{dense_log.name}`",
     "",
     "## Phase Gate",
@@ -170,6 +191,23 @@ if selected_1024 and sparse_1024:
 else:
     lines.append("- Missing `kv=1024,top_k=768` decode comparison rows.")
 
+lines.extend([
+    "",
+    "## Compact Decode Kernel Decision",
+    "",
+])
+if selected_1024 and compact_fallback_1024:
+    ratio = selected_1024["us"] / compact_fallback_1024["us"]
+    lines.append("| Shape | Selected-row fused | Compact gather + flash | Selected/fallback |")
+    lines.append("| --- | ---: | ---: | ---: |")
+    lines.append(f"| `kv=1024, top_k=768` | {selected_1024['us']:.2f} us | {compact_fallback_1024['us']:.2f} us | {ratio:.2f}x |")
+    if selected_1024["us"] <= compact_fallback_1024["us"]:
+        lines.append("- Decision: selected-row fused flash is eligible to promote for this shape.")
+    else:
+        lines.append("- Decision: keep selected-row fused flash opt-in; compact gather + flash is faster for this shape.")
+else:
+    lines.append("- Missing compact gather + flash fallback comparison row.")
+
 lines.extend([
     "",
     "## Short Prefill / Verification Policy",
@@ -191,6 +229,8 @@ lines.extend([
     f"- `{phase_log.name}`",
     f"- `{sparse_log.name}`",
     f"- `{Path(str(sparse_log).replace('.console.log', '.csv')).name}`",
+    f"- `{compact_fallback_log.name}`",
+    f"- `{Path(str(compact_fallback_log).replace('.console.log', '.csv')).name}`",
     f"- `{dense_log.name}`",
     f"- `{Path(str(dense_log).replace('.console.log', '.csv')).name}`",
     "",
diff --git a/tests/test-backend-ops.cpp b/tests/test-backend-ops.cpp
index d607818bd..f3ac1c0d5 100644
--- a/tests/test-backend-ops.cpp
+++ b/tests/test-backend-ops.cpp
@@ -7991,7 +7991,11 @@ struct test_glm_dsa_selected_row_flash : public test_case {
         : kv(kv), top_k(top_k) {}
 
     ggml_tensor * build_graph(ggml_context * ctx) override {
-        set_test_env("SKIPPY_GLM_DSA_EXPERIMENTAL_SELECTED_ROW_FLASH", "1");
+        const char * disabled = getenv("SKIPPY_GLM_DSA_DISABLE_SELECTED_ROW_FLASH");
+        const char * explicit_selected_row = getenv("SKIPPY_GLM_DSA_EXPERIMENTAL_SELECTED_ROW_FLASH");
+        if (!(disabled && atoi(disabled) != 0) && explicit_selected_row == nullptr) {
+            set_test_env("SKIPPY_GLM_DSA_EXPERIMENTAL_SELECTED_ROW_FLASH", "1");
+        }
 
         ggml_tensor * q         = ggml_new_tensor_4d(ctx, GGML_TYPE_F32, 576, 1, 1, 1);
         ggml_tensor * packed_kv = ggml_new_tensor_4d(ctx, GGML_TYPE_F16, 576, kv, 1, 1);
-- 
2.53.0

