From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Mon, 6 Jul 2026 12:00:00 +1000
Subject: [PATCH] Allow GLM DSA decode sideband producer lag

---
 src/skippy.cpp | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 62614186b..76b49d558 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1355,12 +1355,12 @@ static bool skippy_glm_dsa_sideband_top_k_count_is_valid(
     }
 
     // Decode producers export the actual top-k tensor width from their graph.
-    // That can be one token behind the receiving session's accumulated
-    // n_past + token_count expectation because the downstream side validates
-    // after accounting for the current decode token.
-    const uint64_t actual_plus_token_count =
-            static_cast<uint64_t>(actual_top_k) + static_cast<uint64_t>(token_count);
-    return actual_top_k == expected_top_k || actual_plus_token_count == expected_top_k;
+    // The receiving session can have a larger accumulated KV prefix than the
+    // producer's current sideband width, especially when an OpenAI generation
+    // loop advances through cached or fused decode steps. The sideband is still
+    // valid as long as it is non-empty, token-major, and does not claim more
+    // rows than the receiver can make visible.
+    return actual_top_k <= expected_top_k;
 }
 
 static size_t skippy_glm_dsa_top_k_bytes(const skippy_session * session, size_t token_count) {
-- 
2.53.0

