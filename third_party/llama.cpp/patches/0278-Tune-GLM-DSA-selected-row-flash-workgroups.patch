From 36fcb5bc90f34790c6e21faad81523a94d43ec87 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Mon, 6 Jul 2026 21:46:50 +1000
Subject: [PATCH] Tune GLM DSA selected-row flash workgroups

---
 ggml/src/ggml-metal/ggml-metal-ops.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/ggml/src/ggml-metal/ggml-metal-ops.cpp b/ggml/src/ggml-metal/ggml-metal-ops.cpp
index 208a1bf43..0bc9292db 100644
--- a/ggml/src/ggml-metal/ggml-metal-ops.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-ops.cpp
@@ -3312,7 +3312,7 @@ static int32_t ggml_metal_glm_dsa_compact_flash_nwg_requested() {
 static int32_t ggml_metal_glm_dsa_selected_row_flash_nwg_requested() {
     const char * value = getenv("LLAMA_GLM_DSA_SELECTED_ROW_FLASH_NWG");
     if (value == nullptr || value[0] == '\0') {
-        return 32;
+        return 16;
     }
 
     const int requested = atoi(value);
@@ -3325,7 +3325,7 @@ static int32_t ggml_metal_glm_dsa_selected_row_flash_nwg_requested() {
         case 32:
             return requested;
         default:
-            return 32;
+            return 16;
     }
 }
 
-- 
2.53.0

