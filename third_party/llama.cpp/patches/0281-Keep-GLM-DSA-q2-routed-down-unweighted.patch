From fe749a866e75024a39f80def2b535a93faf7af30 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Tue, 7 Jul 2026 02:01:47 +1000
Subject: [PATCH] Keep GLM DSA q2 routed down unweighted

---
 src/llama-graph.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index dc24da9e9..cfe26814c 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -2743,7 +2743,7 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
         arch == LLM_ARCH_GLM_DSA &&
         skippy_glm_dsa_q3_down_weighted_parallel_enabled() &&
         !weight_before_ffn &&
-        (down_exps->type == GGML_TYPE_Q2_K || down_exps->type == GGML_TYPE_Q3_K) &&
+        down_exps->type == GGML_TYPE_Q3_K &&
         down_exps_b == nullptr &&
         down_exps_s == nullptr &&
         weights->type == GGML_TYPE_F32 &&
