From 2b2c926c671b3766c713c069c22c6dd7c5e3689f Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Tue, 7 Jul 2026 03:08:03 +1000
Subject: [PATCH] Allow focused GLM DSA Phase E MoE reports

---
 scripts/glm52-phase-e-moe-report.sh | 19 +++++++++++++++----
 1 file changed, 15 insertions(+), 4 deletions(-)

diff --git a/scripts/glm52-phase-e-moe-report.sh b/scripts/glm52-phase-e-moe-report.sh
index b14dcdec0..8e14e0ca9 100755
--- a/scripts/glm52-phase-e-moe-report.sh
+++ b/scripts/glm52-phase-e-moe-report.sh
@@ -44,16 +44,25 @@ moe_log="${out_dir}/moe-bottleneck-perf.console.log"
 moe_csv="${out_dir}/moe-bottleneck-perf.csv"
 summary="${out_dir}/summary.md"
 
+backend_args=()
+if [[ -n "${GLM52_PHASE_E_BACKEND:-}" ]]; then
+    backend_args=(-b "${GLM52_PHASE_E_BACKEND}")
+fi
+
 echo "== GLM-DSA MoE bottleneck perf rows =="
 moe_filter='n_embd=6144|m=2048|m=4096|m=6144|n_tokens=1|n_tokens=4|n_embd=256'
 "${test_backend_ops}" perf \
+    "${backend_args[@]}" \
     -o TOPK_MOE_GLM_ROUTE,TOPK_MOE_GLM_CONSUMER,TOPK_MOE_GLM_ACTIVATION,GLM_SHEXP_CONSUMER,GLM_SHEXP_COMPONENT,GLM_FFN_CONSUMER,MOE_WEIGHTED_SUM,MUL_MAT_ID \
     -p "${moe_filter}" \
     --output console 2>&1 | tee "${moe_log}"
-"${test_backend_ops}" perf \
-    -o TOPK_MOE_GLM_ROUTE,TOPK_MOE_GLM_CONSUMER,TOPK_MOE_GLM_ACTIVATION,GLM_SHEXP_CONSUMER,GLM_SHEXP_COMPONENT,GLM_FFN_CONSUMER,MOE_WEIGHTED_SUM,MUL_MAT_ID \
-    -p "${moe_filter}" \
-    --output csv > "${moe_csv}"
+if [[ "${GLM52_PHASE_E_SKIP_CSV:-0}" == "0" ]]; then
+    "${test_backend_ops}" perf \
+        "${backend_args[@]}" \
+        -o TOPK_MOE_GLM_ROUTE,TOPK_MOE_GLM_CONSUMER,TOPK_MOE_GLM_ACTIVATION,GLM_SHEXP_CONSUMER,GLM_SHEXP_COMPONENT,GLM_FFN_CONSUMER,MOE_WEIGHTED_SUM,MUL_MAT_ID \
+        -p "${moe_filter}" \
+        --output csv > "${moe_csv}"
+fi
 
 python3 - "${moe_log}" "${summary}" <<'PY'
 import os
@@ -183,6 +192,8 @@ lines = [
     "## Inputs",
     "",
     f"- MoE perf: `{moe_log.name}`",
+    f"- CSV perf: `{'skipped' if os.environ.get('GLM52_PHASE_E_SKIP_CSV', '0') != '0' else 'moe-bottleneck-perf.csv'}`",
+    f"- Backend filter: `{os.environ.get('GLM52_PHASE_E_BACKEND', 'all')}`",
     f"- Phase E gates: `{'required' if require_gates else 'advisory'}`",
     "",
     "## Decode Components",
-- 
2.53.0

