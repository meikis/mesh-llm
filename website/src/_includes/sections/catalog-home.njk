{% from "components/ui.njk" import sectionHead %}

<section class="sec pt-14 sm:pt-20 catalog" id="catalog">
  <div class="shell">
    {{ sectionHead(
      "Mesh-ready model refs, ready to copy.",
      "Browse live Hugging Face catalog data, copy <span class=\"mono\" style=\"color: var(--blue-3);\">org/repo:quant</span> refs, and see which models ship layer packages for multi-machine serving."
