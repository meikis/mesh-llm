    <div class="toolbar" id="catalog-toolbar">
      <label class="control control-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="sr-only">Search models</span>
        <input type="text" id="catalog-search" class="ctrl-input" placeholder="Search models, refs, or families…" aria-label="Search models">
      </label>
      <div class="filter-group" aria-label="Filter controls">
      <label class="control control-select" for="filter-capability">
        <span class="control-label">Capability</span>
        <select id="filter-capability" aria-label="Filter by capability">
          <option value="">Any</option>
          <option value="Code">Code</option>
          <option value="Vision">Vision</option>
          <option value="Long context">Long context</option>
        </select>
      </label>
      <label class="control control-select" for="filter-runtime">
        <span class="control-label">Runtime</span>
        <select id="filter-runtime" aria-label="Filter by runtime">
          <option value="">Any</option>
          <option value="Multi-machine">Multi-machine</option>
          <option value="Single machine">Single machine</option>
        </select>
      </label>
      <label class="control control-select" for="filter-hardware">
        <span class="control-label">Hardware</span>
        <select id="filter-hardware" aria-label="Filter by hardware">
          <option value="">Any</option>
          <option value="&le; 8 GB">&le; 8 GB</option>
          <option value="11–20 GB">11–20 GB</option>
          <option value="40 GB +">40 GB+</option>
        </select>
      </label>
      <label class="control control-select" for="filter-source">
        <span class="control-label">Source</span>
        <select id="filter-source" aria-label="Filter by source">
          <option value="">Any</option>
          <option value="Qwen">Qwen</option>
          <option value="GLM">GLM</option>
          <option value="Gemma">Gemma</option>
          <option value="DeepSeek">DeepSeek</option>
          <option value="Kimi">Kimi</option>
          <option value="Llama">Llama</option>
          <option value="Mistral">Mistral</option>
          <option value="MiniMax">MiniMax</option>
